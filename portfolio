<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>実績・事例 | LANDPLUS.WORK</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Noto+Sans+JP:wght@300;400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<style>
/* ==================================================
   Elementor outer reset / full width fix
   ================================================== */

html,
body {
  margin: 0 !important;
  padding: 0 !important;
  width: 100% !important;
  overflow-x: hidden !important;
}

body.elementor-page {
  margin: 0 !important;
  padding: 0 !important;
}

.elementor,
.elementor-section,
.elementor-container,
.elementor-column,
.elementor-widget-wrap,
.elementor-widget,
.elementor-widget-html,
.elementor-widget-container,
.e-con,
.e-con-inner,
.e-con-full,
.elementor-element {
  margin-top: 0 !important;
  margin-bottom: 0 !important;
  padding-top: 0 !important;
  padding-bottom: 0 !important;
  gap: 0 !important;
  max-width: none !important;
}

.elementor-widget-html,
.elementor-widget-html > .elementor-widget-container {
  width: 100% !important;
  max-width: none !important;
  margin: 0 !important;
  padding: 0 !important;
}

/* ==================================================
   TOKENS
   ================================================== */

:root {
  --dk-bg:    #1a2e4a;
  --dk-bg2:   #152238;
  --dk-blue:  #3d6fa8;
  --dk-gold:  #b07d2b;
  --dk-grid:  rgba(255,255,255,0.033);

  --lt-bg:    #f4f7fb;
  --lt-card:  #ffffff;
  --lt-navy:  #1a2e4a;
  --lt-blue:  #2a5b9e;
  --lt-blue2: #3d6fa8;
  --lt-gold:  #b07d2b;
  --lt-teal:  #2a7a6e;
  --lt-text:  #21364f;
  --lt-text2: #3f566f;
  --lt-text3: #6c8299;
  --lt-bdr:   #dce6f0;
  --lt-bdr2:  #c4d4e4;
  --lt-bg2:   #eaf1f8;

  --mono:  'Share Tech Mono', monospace;
  --serif: 'Noto Serif JP', serif;
  --sans:  'Noto Sans JP', sans-serif;
}

*, *::before, *::after {
  box-sizing: border-box;
}

.lp-works-page {
  width: 100vw !important;
  margin-left: calc(50% - 50vw) !important;
  margin-right: calc(50% - 50vw) !important;
  overflow-x: hidden;
  background: var(--lt-bg);
  color: var(--lt-text);
  font-family: var(--sans);
  font-weight: 400;
  line-height: 1.7;
}

/* ==================================================
   HEADER
   ================================================== */

.lp-header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  z-index: 200;
  background: var(--dk-bg2);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40px;
  height: 60px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  box-shadow: 0 2px 14px rgba(0,0,0,0.35);
}

.lp-logo {
  text-decoration: none;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.lp-logo-main {
  font-family: var(--mono);
  font-size: 14px;
  letter-spacing: .16em;
  color: #fff;
}

.lp-logo-sub {
  font-size: 9px;
  letter-spacing: .22em;
  color: rgba(255,255,255,.48);
  text-transform: uppercase;
}

.lp-nav {
  display: flex;
  align-items: center;
  gap: 28px;
}

.lp-nav a {
  font-size: 11.5px;
  letter-spacing: .10em;
  text-decoration: none;
  color: rgba(255,255,255,.70);
  transition: color .18s;
  font-weight: 500;
}

.lp-nav a:hover,
.lp-nav a.on {
  color: #fff;
}

.lp-nav-cta {
  background: var(--dk-gold);
  color: #fff !important;
  padding: 8px 18px;
  border-radius: 2px;
  font-size: 11px;
  letter-spacing: .13em;
}

.lp-nav-cta:hover {
  background: #c48f35 !important;
}

/* ==================================================
   HERO
   ================================================== */

.lp-page-hero {
  margin-top: 60px;
  width: 100vw;
  background: linear-gradient(150deg,#1a2e4a 0%,#1d3457 45%,#233f6a 100%);
  padding: 64px 0 56px;
  position: relative;
  overflow: hidden;
}

.lp-page-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(var(--dk-grid) 1px,transparent 1px),
    linear-gradient(90deg,var(--dk-grid) 1px,transparent 1px);
  background-size: 44px 44px;
}

.lp-hero-deco-svg {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 380px;
  opacity: .06;
  pointer-events: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lp-hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 48px;
  position: relative;
}

.lp-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .20em;
  color: rgba(255,255,255,.42);
  margin-bottom: 20px;
  text-transform: uppercase;
}

.lp-breadcrumb a {
  color: rgba(255,255,255,.42);
  text-decoration: none;
  transition: color .2s;
}

.lp-breadcrumb a:hover {
  color: rgba(255,255,255,.72);
}

.lp-page-label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .40em;
  color: #e8b96a;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

.lp-page-label::before {
  content: '';
  width: 28px;
  height: 1px;
  background: #e8b96a;
}

.lp-page-hero h1 {
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(28px,3vw,40px);
  letter-spacing: .07em;
  color: #fff;
  margin: 0 0 12px;
  line-height: 1.35;
}

.lp-page-hero h1 span {
  display: block;
  font-size: .62em;
  color: rgba(255,255,255,.76);
  letter-spacing: .05em;
  margin-top: 6px;
  font-weight: 300;
}

.lp-page-hero-desc {
  font-size: 13.5px;
  letter-spacing: .04em;
  color: rgba(255,255,255,.62);
  line-height: 1.95;
  max-width: 680px;
  margin: 0;
}

/* ==================================================
   SECTION COMMON
   ================================================== */

.lp-sec {
  width: 100vw;
  padding: 72px 0;
  background: var(--lt-bg);
}

.lp-sec.alt {
  background: var(--lt-card);
}

.lp-sec.dark {
  background: var(--dk-bg);
  color: rgba(255,255,255,.88);
}

.lp-sec-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 48px;
}

.lp-sec-label {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .42em;
  color: var(--lt-blue);
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.lp-sec-label::before {
  content: '';
  width: 18px;
  height: 1px;
  background: var(--lt-blue);
}

.lp-sec.dark .lp-sec-label {
  color: #7cb8e8;
}

.lp-sec.dark .lp-sec-label::before {
  background: #7cb8e8;
}

.lp-sec-h2 {
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(24px,2.4vw,34px);
  letter-spacing: .07em;
  color: var(--lt-navy);
  margin: 0 0 10px;
  line-height: 1.4;
}

.lp-sec.dark .lp-sec-h2 {
  color: #d8eaf8;
}

.lp-sec-desc {
  font-size: 13.5px;
  color: var(--lt-text2);
  letter-spacing: .04em;
  line-height: 1.95;
  margin: 0 0 48px;
  max-width: 580px;
}

.lp-sec.dark .lp-sec-desc {
  color: rgba(255,255,255,.58);
}

/* ==================================================
   SUMMARY
   ================================================== */

.lp-summary-grid {
  display: grid;
  grid-template-columns: repeat(4,1fr);
  gap: 1px;
  background: var(--lt-bdr);
  border: 1px solid var(--lt-bdr);
  border-radius: 3px;
  overflow: hidden;
}

.lp-sum-card {
  background: var(--lt-card);
  padding: 28px 24px 26px;
  position: relative;
  border-top: 3px solid transparent;
  transition: border-color .2s, background .2s;
}

.lp-sum-card:hover {
  border-top-color: var(--lt-blue);
  background: #f8fbff;
}

.lp-sum-icon {
  width: 36px;
  height: 36px;
  border-radius: 3px;
  background: rgba(42,91,158,.09);
  border: 1px solid rgba(42,91,158,.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
}

.lp-sum-icon svg {
  width: 18px;
  height: 18px;
  stroke: var(--lt-blue);
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.lp-sum-ttl {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .32em;
  color: var(--lt-blue);
  text-transform: uppercase;
  margin-bottom: 10px;
}

.lp-sum-val {
  font-family: var(--serif);
  font-size: 15px;
  color: var(--lt-navy);
  line-height: 1.55;
  font-weight: 400;
  letter-spacing: .04em;
}

.lp-sum-sub {
  font-size: 11.5px;
  color: var(--lt-text3);
  margin-top: 6px;
  letter-spacing: .03em;
  line-height: 1.7;
}

/* ==================================================
   FIELD RECORDS
   ================================================== */

.lp-field-block {
  margin-bottom: 56px;
}

.lp-field-block:last-child {
  margin-bottom: 0;
}

.lp-field-header {
  display: flex;
  align-items: baseline;
  gap: 14px;
  margin-bottom: 24px;
  padding-bottom: 14px;
  border-bottom: 2px solid var(--lt-bdr);
}

.lp-field-num {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--lt-blue);
  letter-spacing: .2em;
}

.lp-field-ttl {
  font-family: var(--serif);
  font-size: 21px;
  color: var(--lt-navy);
  font-weight: 400;
  letter-spacing: .05em;
}

.lp-field-count {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .14em;
  color: var(--lt-text3);
  margin-left: auto;
  background: var(--lt-bg2);
  padding: 3px 10px;
  border-radius: 10px;
}

.lp-case-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 18px;
}

.lp-case-card {
  background: var(--lt-card);
  border: 1px solid var(--lt-bdr);
  border-radius: 3px;
  padding: 24px;
  position: relative;
  overflow: hidden;
  transition: box-shadow .22s, transform .22s, border-color .22s;
}

.lp-case-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 3px;
  background: var(--lt-blue2);
  transform: scaleY(0);
  transform-origin: top;
  transition: transform .2s ease;
}

.lp-case-card:hover {
  box-shadow: 0 6px 22px rgba(26,46,74,.10);
  transform: translateY(-3px);
  border-color: var(--lt-bdr2);
}

.lp-case-card:hover::before {
  transform: scaleY(1);
}

.lp-case-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
  margin-bottom: 14px;
}

.lp-case-tag {
  font-family: var(--mono);
  font-size: 8.5px;
  letter-spacing: .12em;
  padding: 3px 9px;
  border-radius: 1px;
  color: #fff;
}

.lp-ct-blue { background: var(--lt-blue2); }
.lp-ct-teal { background: var(--lt-teal); }
.lp-ct-gold { background: var(--lt-gold); }
.lp-ct-navy { background: var(--lt-navy); }

.lp-case-ttl {
  font-size: 14px;
  color: var(--lt-navy);
  letter-spacing: .04em;
  font-weight: 500;
  line-height: 1.55;
  margin-bottom: 10px;
}

.lp-case-client {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .10em;
  color: var(--lt-text3);
  margin-bottom: 14px;
}

.lp-case-rows {
  border-top: 1px solid var(--lt-bdr);
  padding-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.lp-case-row {
  display: flex;
  gap: 10px;
  font-size: 12px;
  letter-spacing: .03em;
}

.lp-cr-label {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .14em;
  color: var(--lt-text3);
  text-transform: uppercase;
  min-width: 44px;
  padding-top: 2px;
  flex-shrink: 0;
}

.lp-cr-val {
  color: var(--lt-text2);
  line-height: 1.6;
}

/* ==================================================
   FEATURED CASES
   ================================================== */

.lp-featured-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
}

.lp-feat-card {
  background: var(--lt-card);
  border: 1px solid var(--lt-bdr);
  border-radius: 4px;
  overflow: hidden;
}

.lp-feat-header {
  background: linear-gradient(135deg,var(--dk-bg) 0%,#223d6a 100%);
  padding: 28px 30px;
  position: relative;
  overflow: hidden;
}

.lp-feat-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size: 32px 32px;
}

.lp-feat-num {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .38em;
  color: rgba(255,255,255,.42);
  text-transform: uppercase;
  margin-bottom: 12px;
  position: relative;
}

.lp-feat-title {
  font-family: var(--serif);
  font-size: 19px;
  color: #fff;
  font-weight: 400;
  letter-spacing: .06em;
  line-height: 1.45;
  margin-bottom: 8px;
  position: relative;
}

.lp-feat-facility {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .14em;
  color: rgba(255,255,255,.50);
  position: relative;
}

.lp-feat-svg {
  position: absolute;
  right: 20px;
  bottom: 16px;
  opacity: .12;
  pointer-events: none;
}

.lp-feat-body {
  padding: 26px 30px;
}

.lp-feat-table {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 20px;
}

.lp-feat-table tr {
  border-bottom: 1px solid var(--lt-bdr);
}

.lp-feat-table tr:last-child {
  border-bottom: none;
}

.lp-feat-table td {
  padding: 10px 0;
  vertical-align: top;
}

.lp-ft-lbl {
  font-family: var(--mono);
  font-size: 9px;
  letter-spacing: .18em;
  color: var(--lt-blue);
  text-transform: uppercase;
  width: 108px;
  padding-right: 14px;
  padding-top: 2px;
  flex-shrink: 0;
  line-height: 1.6;
}

.lp-ft-val {
  font-size: 12.5px;
  color: var(--lt-text2);
  line-height: 1.7;
  letter-spacing: .03em;
}

.lp-feat-points {
  background: var(--lt-bg2);
  border-left: 3px solid var(--lt-blue);
  padding: 14px 16px;
  border-radius: 0 2px 2px 0;
}

.lp-feat-points-lbl {
  font-family: var(--mono);
  font-size: 8.5px;
  letter-spacing: .22em;
  color: var(--lt-blue);
  text-transform: uppercase;
  margin-bottom: 8px;
}

.lp-feat-points ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 5px;
  margin: 0;
  padding: 0;
}

.lp-feat-points li {
  display: flex;
  gap: 8px;
  font-size: 12px;
  color: var(--lt-text2);
  letter-spacing: .03em;
  line-height: 1.65;
}

.lp-feat-points li::before {
  content: '—';
  color: var(--lt-blue);
  flex-shrink: 0;
  margin-top: 1px;
}

/* ==================================================
   SCOPE
   ================================================== */

.lp-scope-grid {
  display: grid;
  grid-template-columns: repeat(2,1fr);
  gap: 24px;
}

.lp-scope-col {
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 3px;
  padding: 28px;
}

.lp-scope-col-ttl {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .30em;
  color: #7cb8e8;
  text-transform: uppercase;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.lp-scope-col-ttl::before {
  content: '';
  width: 12px;
  height: 1px;
  background: #7cb8e8;
}

.lp-scope-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
  margin: 0;
  padding: 0;
}

.lp-scope-list li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 9px 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
  font-size: 13px;
  letter-spacing: .03em;
  color: rgba(255,255,255,.76);
  line-height: 1.65;
}

.lp-scope-list li:last-child {
  border-bottom: none;
}

.lp-scope-list li::before {
  content: '';
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--dk-blue);
  flex-shrink: 0;
  margin-top: 8px;
}

/* ==================================================
   QUALITY
   ================================================== */

.lp-qc-grid {
  display: grid;
  grid-template-columns: repeat(3,1fr);
  gap: 20px;
}

.lp-qc-card {
  background: #fff;
  border: 1px solid var(--lt-bdr);
  border-radius: 3px;
  padding: 24px;
}

.lp-qc-icon {
  width: 38px;
  height: 38px;
  border-radius: 2px;
  background: rgba(42,91,158,.08);
  border: 1px solid rgba(42,91,158,.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14px;
}

.lp-qc-icon svg {
  width: 18px;
  height: 18px;
  stroke: var(--lt-blue2);
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.lp-qc-ttl {
  font-family: var(--serif);
  font-size: 15px;
  color: var(--lt-navy);
  font-weight: 400;
  letter-spacing: .05em;
  margin-bottom: 8px;
  line-height: 1.45;
}

.lp-qc-body {
  font-size: 12.5px;
  color: var(--lt-text2);
  letter-spacing: .03em;
  line-height: 1.85;
}

/* ==================================================
   CTA
   ================================================== */

.lp-cta-sec {
  width: 100vw;
  background: linear-gradient(135deg,#1a2e4a 0%,#1e3557 50%,#243f6e 100%);
  padding: 72px 0;
  position: relative;
  overflow: hidden;
}

.lp-cta-sec::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size: 44px 44px;
}

.lp-cta-inner {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 48px;
  text-align: center;
  position: relative;
}

.lp-cta-label {
  font-family: var(--mono);
  font-size: 9.5px;
  letter-spacing: .40em;
  color: #e8b96a;
  text-transform: uppercase;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
}

.lp-cta-label::before,
.lp-cta-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #e8b96a;
  max-width: 32px;
}

.lp-cta-h2 {
  font-family: var(--serif);
  font-size: 28px;
  color: #fff;
  font-weight: 400;
  letter-spacing: .07em;
  margin: 0 0 18px;
  line-height: 1.4;
}

.lp-cta-desc {
  font-size: 13.5px;
  color: rgba(255,255,255,.62);
  letter-spacing: .04em;
  line-height: 2;
  margin: 0 0 36px;
}

.lp-cta-btns {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
}

.lp-btn-gold,
.lp-btn-wht {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  font-size: 12.5px;
  letter-spacing: .18em;
  text-decoration: none;
  border-radius: 2px;
  cursor: pointer;
  font-family: var(--sans);
  transition: background .2s, transform .2s, border-color .2s, color .2s;
}

.lp-btn-gold {
  background: var(--dk-gold);
  color: #fff;
  border: none;
}

