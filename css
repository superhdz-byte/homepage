/* ==================================================
   LANDPLUS.WORK 共通CSS 完整替换版
   用途：
   1. 固定ページ：全幅・紺色ベース・Elementor用
   2. 投稿ページ：白背景・記事本文を正常表示
   3. WordPressヘッダー：固定表示
   4. ナビ：右寄せ・文字調整
   5. Footer調整
   6. HOME お知らせ联动修正
   ================================================== */


/* ==================================================
   01. 基本変数
   ================================================== */

:root {
  --lp-header-height: 78px;
  --lp-blue-dark: #071d35;
  --lp-blue-main: #0b2a4a;
  --lp-blue-head: #0d2543;
  --lp-bg-navy: #0d2543;
  --lp-gold: #d8a94a;
  --lp-gold-dark: #b77a16;
  --lp-text-dark: #111827;
  --lp-text-gray: #374151;
}


/* ==================================================
   02. 基本リセット
   ================================================== */

html,
body {
  margin: 0 !important;
  padding: 0 !important;
  overflow-x: hidden !important;
}

body {
  padding-top: var(--lp-header-height) !important;
  background: var(--lp-bg-navy) !important;
}

body.admin-bar {
  padding-top: var(--lp-header-height) !important;
}


/* ==================================================
   03. 固定ページ専用：タイトル・パンくず非表示
   注意：投稿ページには適用しない
   ================================================== */

body.page .entry-header,
body.page .page-header,
body.page .page-title,
body.page .entry-title,
body.page .site-description,
body.page .header-inner .site-description,
body.page .breadcrumb,
body.page .breadcrumbs,
body.page .rank-math-breadcrumb {
  display: none !important;
  margin: 0 !important;
  padding: 0 !important;
}


/* ==================================================
   04. 固定ページ専用：本文を全幅化
   注意：投稿ページには適用しない
   ================================================== */

body.page,
body.page #page,
body.page .site,
body.page .site-content,
body.page .content-area,
body.page .site-main,
body.page .page-content,
body.page .entry-content {
  margin: 0 !important;
  padding: 0 !important;
  max-width: none !important;
  width: 100% !important;
  background: transparent !important;
}


/* ==================================================
   05. Elementor 余白対策
   ================================================== */

.elementor,
.elementor-section,
.elementor-container,
.elementor-column,
.elementor-widget-wrap,
.elementor-widget-html,
.elementor-widget-html .elementor-widget-container {
  max-width: 100% !important;
  margin-top: 0 !important;
  padding-top: 0 !important;
}

.elementor-widget:not(:last-child) {
  margin-bottom: 0 !important;
}

.elementor-element:first-child,
.elementor-section:first-child,
.elementor-widget:first-child {
  margin-top: 0 !important;
  padding-top: 0 !important;
}


/* ==================================================
   06. WordPress ヘッダー固定
   ================================================== */

.site-header,
#masthead,
header.site-header {
  position: fixed !important;
  top: 0 !important;
  left: 0 !important;
  right: 0 !important;
  width: 100% !important;
  height: var(--lp-header-height) !important;
  min-height: var(--lp-header-height) !important;
  z-index: 99999 !important;
  background: var(--lp-blue-head) !important;
  margin: 0 !important;
  padding: 0 !important;
  border-bottom: none !important;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.16) !important;
}

.site-header::after,
#masthead::after,
header.site-header::after {
  content: '' !important;
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  bottom: 0 !important;
  height: 1px !important;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(216,169,74,0.45) 30%,
    rgba(216,169,74,0.45) 70%,
    transparent 100%
  ) !important;
  pointer-events: none !important;
}

body.admin-bar .site-header,
body.admin-bar #masthead,
body.admin-bar header.site-header {
  top: 32px !important;
}


/* ==================================================
   07. ヘッダー内側レイアウト
   ================================================== */

.site-header .header-inner,
.site-header .site-header-inner,
header.site-header .header-inner,
header.site-header .site-header-inner {
  max-width: 1500px !important;
  width: 100% !important;
  height: var(--lp-header-height) !important;
  margin: 0 auto !important;
  padding: 0 36px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: space-between !important;
  gap: 40px !important;
  box-sizing: border-box !important;
}

.site-branding,
.site-logo,
.header-logo,
.site-title {
  flex-shrink: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  margin-right: auto !important;
}

.site-title,
.site-title a,
.site-branding a {
  color: #ffffff !important;
  text-decoration: none !important;
  font-size: 19px !important;
  font-weight: 800 !important;
  letter-spacing: 0.18em !important;
  line-height: 1.15 !important;
  white-space: nowrap !important;
}

.site-title a::after {
  content: 'SEISMIC ANALYSIS · CIVIL ENGINEERING';
  display: block !important;
  font-size: 8.5px !important;
  font-weight: 400 !important;
  letter-spacing: 0.16em !important;
  color: rgba(255,255,255,0.36) !important;
  text-transform: uppercase !important;
  margin-top: 4px !important;
  line-height: 1 !important;
}


/* ==================================================
   08. グローバルナビ
   ================================================== */

.site-header nav,
.site-header .main-navigation,
.site-header .primary-navigation,
.site-header .site-navigation {
  display: block !important;
  margin-left: auto !important;
  margin-right: 0 !important;
  padding: 0 !important;
  flex: 1 1 auto !important;
}

.site-header nav ul,
.site-header .main-navigation ul,
.site-header .primary-navigation ul,
.site-header .site-navigation ul {
  display: flex !important;
  align-items: center !important;
  justify-content: flex-end !important;
  gap: 38px !important;
  width: 100% !important;
  margin: 0 !important;
  padding: 0 !important;
  list-style: none !important;
}

.site-header nav li,
.site-header .main-navigation li,
.site-header .primary-navigation li,
.site-header .site-navigation li {
  margin: 0 !important;
  padding: 0 !important;
}

.site-header nav a,
.site-header .main-navigation a,
.site-header .primary-navigation a,
.site-header .site-navigation a {
  display: inline-flex !important;
  align-items: center !important;
  position: relative !important;
  color: rgba(255,255,255,0.90) !important;
  text-decoration: none !important;
  font-size: 15px !important;
  font-weight: 700 !important;
  letter-spacing: 0.07em !important;
  line-height: 1.4 !important;
  padding: 4px 0 !important;
  white-space: nowrap !important;
  transition: color 0.22s ease !important;
}

.site-header nav li:not(:last-child) a:hover,
.site-header .main-navigation li:not(:last-child) a:hover,
.site-header .primary-navigation li:not(:last-child) a:hover,
.site-header .site-navigation li:not(:last-child) a:hover {
  color: #ffffff !important;
}

.site-header nav li:not(:last-child) a::after,
.site-header .main-navigation li:not(:last-child) a::after,
.site-header .primary-navigation li:not(:last-child) a::after,
.site-header .site-navigation li:not(:last-child) a::after {
  content: '' !important;
  position: absolute !important;
  left: 0 !important;
  bottom: -4px !important;
  width: 100% !important;
  height: 1.5px !important;
  background: var(--lp-gold) !important;
  transform: scaleX(0) !important;
  transform-origin: left !important;
  transition: transform 0.24s ease !important;
}

.site-header nav li:not(:last-child) a:hover::after,
.site-header .main-navigation li:not(:last-child) a:hover::after,
.site-header .primary-navigation li:not(:last-child) a:hover::after,
.site-header .site-navigation li:not(:last-child) a:hover::after,
.site-header nav .current-menu-item a::after,
.site-header .main-navigation .current-menu-item a::after,
.site-header .primary-navigation .current-menu-item a::after,
.site-header nav .current_page_item a::after,
.site-header .main-navigation .current_page_item a::after {
  transform: scaleX(1) !important;
}


/* ==================================================
   09. お問い合わせボタン
   ================================================== */

.site-header nav li:last-child a,
.site-header .main-navigation li:last-child a,
.site-header .primary-navigation li:last-child a,
.site-header .site-navigation li:last-child a {
  background: transparent !important;
  border: 1.5px solid rgba(216,169,74,0.85) !important;
  color: var(--lp-gold) !important;
  padding: 12px 24px !important;
  border-radius: 2px !important;
  font-size: 14px !important;
  font-weight: 800 !important;
  letter-spacing: 0.10em !important;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease !important;
}

.site-header nav li:last-child a:hover,
.site-header .main-navigation li:last-child a:hover,
.site-header .primary-navigation li:last-child a:hover,
.site-header .site-navigation li:last-child a:hover {
  background: rgba(216,169,74,0.14) !important;
  border-color: var(--lp-gold) !important;
  color: #e8c060 !important;
}

.site-header nav li:last-child a::after,
.site-header .main-navigation li:last-child a::after,
.site-header .primary-navigation li:last-child a::after,
.site-header .site-navigation li:last-child a::after {
  display: none !important;
}


/* ==================================================
   10. 固定ページ Hero 接続対策
   ================================================== */

body.page .site-content,
body.page .content-area,
body.page .site-main,
body.page .entry-content,
body.page .elementor,
body.page .elementor-section:first-child {
  margin-top: 0 !important;
}

body.page .hero,
body.page .lp-hero,
body.page section.hero,
body.page section.lp-hero {
  margin-top: 0 !important;
}

body.page .lp-hero-kicker,
body.page .hero-kicker,
body.page .elementor .lp-hero-kicker,
body.page .elementor .hero-kicker {
  margin-top: 34px !important;
  margin-bottom: 42px !important;
}

body.page .lp-hero .lp-hero-kicker,
body.page .hero .hero-kicker,
body.page .elementor .lp-hero .lp-hero-kicker,
body.page .elementor .hero .hero-kicker {
  position: relative !important;
  top: 22px !important;
}

body.page .lp-hero,
body.page .hero,
body.page .elementor .lp-hero,
body.page .elementor .hero {
  padding-top: 96px !important;
}


/* ==================================================
   11. 投稿ページ専用：白背景・記事本文正常化
   ================================================== */

body.single-post,
body.post-template-default {
  background: #ffffff !important;
  color: var(--lp-text-dark) !important;
}

/* 投稿ページ全体 */
body.single-post #page,
body.single-post .site,
body.single-post .site-content,
body.single-post .content-area,
body.single-post .site-main,
body.single-post main,
body.single-post .wp-site-blocks,
body.single-post .ast-container,
body.single-post .container,
body.single-post .content-wrap {
  background: #ffffff !important;
  background-color: #ffffff !important;
  color: var(--lp-text-dark) !important;
}

/* 投稿ページの本文エリア */
body.single-post .site-main {
  max-width: 980px !important;
  width: calc(100% - 48px) !important;
  margin: 0 auto !important;
  padding: 54px 0 90px !important;
  box-sizing: border-box !important;
}

/* 投稿記事本体 */
body.single-post article.post,
body.single-post .type-post,
body.single-post .hentry {
  max-width: 880px !important;
  width: 100% !important;
  margin: 0 auto !important;
  padding: 0 !important;
  background: #ffffff !important;
  color: var(--lp-text-dark) !important;
  box-sizing: border-box !important;
}

/* 投稿ページではタイトルを必ず表示 */
body.single-post .entry-header,
body.single-post .entry-title {
  display: block !important;
  visibility: visible !important;
}

/* 投稿タイトル */
body.single-post .entry-title,
body.single-post h1.entry-title {
  color: var(--lp-text-dark) !important;
  font-size: 38px !important;
  line-height: 1.35 !important;
  font-weight: 800 !important;
  letter-spacing: 0.03em !important;
  margin: 0 0 34px !important;
  padding: 0 !important;
}

/* 投稿メタ情報 */
body.single-post .entry-meta,
body.single-post .posted-on,
body.single-post .byline {
  color: #6b7280 !important;
  font-size: 13px !important;
  line-height: 1.7 !important;
  margin: 0 0 28px !important;
}

/* 投稿本文 */
body.single-post .entry-content {
  max-width: 880px !important;
  width: 100% !important;
  margin: 0 auto !important;
  padding: 0 !important;
  background: #ffffff !important;
  color: var(--lp-text-dark) !important;
  box-sizing: border-box !important;
}

/* 投稿本文文字 */
body.single-post .entry-content,
body.single-post .entry-content p,
body.single-post .entry-content li,
body.single-post .entry-content div,
body.single-post .entry-content span {
  color: var(--lp-text-dark) !important;
  font-size: 16px !important;
  line-height: 2.0 !important;
  font-weight: 500 !important;
}

/* 段落 */
body.single-post .entry-content p {
  margin: 0 0 20px !important;
}

/* リスト */
body.single-post .entry-content ul,
body.single-post .entry-content ol {
  margin: 18px 0 28px 1.4em !important;
  padding: 0 !important;
}

body.single-post .entry-content li {
  margin: 0 0 8px !important;
}

/* 見出し */
body.single-post .entry-content h2 {
  color: var(--lp-text-dark) !important;
  font-size: 28px !important;
  font-weight: 800 !important;
  line-height: 1.45 !important;
  margin: 56px 0 24px !important;
  padding: 0 0 12px !important;
  border-bottom: 2px solid var(--lp-gold) !important;
}

body.single-post .entry-content h3 {
  color: var(--lp-text-dark) !important;
  font-size: 22px !important;
  font-weight: 800 !important;
  line-height: 1.5 !important;
  margin: 40px 0 18px !important;
}

/* 投稿リンク */
body.single-post .entry-content a {
  color: #0b4ecb !important;
  text-decoration: underline !important;
  font-weight: 700 !important;
}

body.single-post .entry-content a:hover {
  color: var(--lp-gold-dark) !important;
}

/* PDFリンク */
body.single-post .entry-content a[href$=".pdf"],
body.single-post .entry-content a[href*=".pdf"] {
  display: inline-block !important;
  color: #0b4ecb !important;
  font-weight: 700 !important;
  text-decoration: underline !important;
}

/* 投稿画像 */
body.single-post .entry-content img,
body.single-post img {
  max-width: 100% !important;
  height: auto !important;
  display: block !important;
  margin: 36px auto !important;
  background: #ffffff !important;
}

/* 図表 */
body.single-post .wp-block-image,
body.single-post figure {
  background: #ffffff !important;
  margin: 36px auto !important;
  text-align: center !important;
}

/* 画像キャプション */
body.single-post figcaption,
body.single-post .wp-element-caption {
  color: #6b7280 !important;
  font-size: 13px !important;
  line-height: 1.7 !important;
  text-align: center !important;
  margin-top: 10px !important;
}

/* 投稿ページ内のElementorがある場合も白背景 */
body.single-post .elementor,
body.single-post .elementor-section,
body.single-post .elementor-container,
body.single-post .elementor-column,
body.single-post .elementor-widget-wrap,
body.single-post .elementor-widget-container {
  background: #ffffff !important;
  background-color: #ffffff !important;
  color: var(--lp-text-dark) !important;
}

/* 投稿ナビ・カテゴリ */
body.single-post .cat-links,
body.single-post .tags-links,
body.single-post .post-navigation,
body.single-post .comments-area {
  max-width: 880px !important;
  margin: 40px auto !important;
  color: var(--lp-text-dark) !important;
  background: #ffffff !important;
}

body.single-post .post-navigation a,
body.single-post .cat-links a,
body.single-post .tags-links a {
  color: #0b4ecb !important;
  text-decoration: none !important;
  font-weight: 700 !important;
}


/* ==================================================
   12. Footer 基本
   ================================================== */

.site-footer,
footer.site-footer,
#colophon,
.elementor-location-footer {
  background: var(--lp-blue-dark) !important;
  color: #ffffff !important;
  border-top: 2px solid rgba(57,124,190,0.85) !important;
}

.elementor-location-footer .elementor-section,
.elementor-location-footer .elementor-container,
.elementor-location-footer .elementor-column,
.elementor-location-footer .elementor-widget-wrap {
  margin-top: 0 !important;
}

.elementor-location-footer .elementor-section,
.elementor-location-footer .elementor-container {
  padding-top: 36px !important;
  padding-bottom: 36px !important;
}

.site-footer,
.site-footer p,
.site-footer span,
.site-footer a,
.elementor-location-footer,
.elementor-location-footer p,
.elementor-location-footer span,
.elementor-location-footer a {
  color: rgba(255,255,255,0.72) !important;
  font-size: 13px !important;
  letter-spacing: 0.08em !important;
  text-decoration: none !important;
}

.site-footer a:hover,
.elementor-location-footer a:hover {
  color: var(--lp-gold) !important;
}


/* ==================================================
   13. 手書きFooter用クラス
   ================================================== */

