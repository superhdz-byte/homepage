  color: var(--lp-blue-dark) !important;
}

.lp-footer-bottom {
  margin-top: 56px !important;
  padding-top: 22px !important;
  border-top: 1px solid rgba(255,255,255,0.12) !important;
  display: flex !important;
  justify-content: space-between !important;
  gap: 24px !important;
  font-size: 12px !important;
  letter-spacing: 0.08em !important;
  color: rgba(255,255,255,0.46) !important;
}


/* ==================================================
   14. Footer下に出る重複ナビを非表示
   ================================================== */

footer + nav,
footer + header,
footer + .main-navigation,
footer + .site-navigation,
footer + .elementor-location-header,
footer + .elementor-section,
.elementor-location-footer + .elementor-location-header,
.elementor-location-footer ~ .elementor-location-header,
.elementor-location-footer + header,
.elementor-location-footer ~ header,
footer ~ .elementor-location-header,
footer ~ .hfe-header,
footer ~ .hfe-nav-menu,
footer ~ .main-header-bar {
  display: none !important;
}

body > .elementor-location-header:last-child,
body > header:last-child {
  display: none !important;
}


/* ==================================================
   15. HOME お知らせ section 表示修正
   ================================================== */

.lp-news-section,
.lp-home-news,
.lp-news-area,
section:has(#lp-auto-news),
.elementor-section:has(#lp-auto-news) {
  height: auto !important;
  min-height: auto !important;
  max-height: none !important;
  overflow: visible !important;
  padding-top: 90px !important;
  padding-bottom: 120px !important;
  margin-bottom: 0 !important;
}

.elementor-container:has(#lp-auto-news),
.elementor-column:has(#lp-auto-news),
.elementor-widget-wrap:has(#lp-auto-news),
.elementor-widget-container:has(#lp-auto-news) {
  height: auto !important;
  min-height: auto !important;
  max-height: none !important;
  overflow: visible !important;
}

#lp-auto-news {
  width: 100%;
  height: auto !important;
  min-height: auto !important;
  max-height: none !important;
  overflow: visible !important;
  margin-top: 54px !important;
  margin-bottom: 48px !important;
}

#lp-auto-news .lp-news-item {
  display: grid !important;
  grid-template-columns: 110px 110px 1fr !important;
  align-items: center !important;
