<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>技術資料 | LANDPLUS.WORK</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&family=Noto+Sans+JP:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root {
  --dk-bg:    #1a2e4a;
  --dk-bg2:   #152238;
  --dk-blue:  #3d6fa8;
  --dk-gold:  #b07d2b;
  --lt-bg:    #f4f7fb;
  --lt-card:  #ffffff;
  --lt-navy:  #1a2e4a;
  --lt-blue:  #2a5b9e;
  --lt-blue2: #3d6fa8;
  --lt-gold:  #b07d2b;
  --lt-teal:  #2a7a6e;
  --lt-text:  #21364f;
  --lt-text2: #3f566f;
  --lt-text3: #6c8299;
  --lt-bdr:   #dce6f0;
  --lt-bdr2:  #c4d4e4;
  --lt-bg2:   #eaf1f8;
  --mono:  'Share Tech Mono', monospace;
  --serif: 'Noto Serif JP', serif;
  --sans:  'Noto Sans JP', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; }
body { background: var(--lt-bg); color: var(--lt-text); font-family: var(--sans); font-weight: 400; line-height: 1.7; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

/* HEADER */
.lp-header {
  position: sticky; top: 0; left: 0; width: 100%; z-index: 9999;
  background: var(--dk-bg2); display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px; height: 66px; border-bottom: 1px solid rgba(255,255,255,0.06);
  box-shadow: 0 2px 14px rgba(0,0,0,0.35);
}
.lp-logo { text-decoration: none; display: flex; flex-direction: column; gap: 2px; }
.lp-logo-main { font-family: var(--mono); font-size: 15px; letter-spacing: .18em; color: #fff; font-weight: 600; }
.lp-logo-sub { font-size: 9px; letter-spacing: .22em; color: rgba(255,255,255,.48); text-transform: uppercase; }
.lp-nav { display: flex; align-items: center; gap: 26px; }
.lp-nav a { font-size: 12px; font-weight: 600; letter-spacing: .10em; text-decoration: none; color: rgba(255,255,255,.72); transition: color .18s; }
.lp-nav a:hover, .lp-nav a.on { color: #fff; }
.lp-nav a.on { border-bottom: 2px solid var(--dk-gold); padding-bottom: 2px; }
.lp-nav-cta { background: var(--dk-gold); color: #fff !important; padding: 9px 20px; border-radius: 2px; font-size: 11px; letter-spacing: .13em; border-bottom: none !important; }
.lp-nav-cta:hover { background: #c48f35 !important; }

/* HERO */
.lp-hero {
  width: 100%; background: linear-gradient(150deg,#1a2e4a 0%,#1d3457 45%,#223960 100%);
  padding: 64px 0 56px; position: relative; overflow: hidden;
}
.lp-hero::before {
  content: ''; position: absolute; inset: 0;
  background-image: linear-gradient(rgba(255,255,255,.028) 1px,transparent 1px), linear-gradient(90deg,rgba(255,255,255,.028) 1px,transparent 1px);
  background-size: 44px 44px;
}
.lp-hero-deco { position: absolute; right: 0; top: 0; bottom: 0; width: 420px; opacity: .07; pointer-events: none; display: flex; align-items: center; justify-content: center; }
.lp-inner { max-width: 1280px; margin: 0 auto; padding: 0 48px; position: relative; }
.lp-breadcrumb { display: flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: 9.5px; letter-spacing: .20em; color: rgba(255,255,255,.38); margin-bottom: 20px; text-transform: uppercase; }
.lp-breadcrumb a { color: rgba(255,255,255,.38); text-decoration: none; transition: color .2s; }
.lp-breadcrumb a:hover { color: rgba(255,255,255,.70); }
.lp-page-label { font-family: var(--mono); font-size: 10px; letter-spacing: .40em; color: #e8b96a; text-transform: uppercase; display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
.lp-page-label::before { content: ''; width: 28px; height: 1px; background: #e8b96a; }
.lp-hero h1 { font-family: var(--serif); font-weight: 400; font-size: clamp(28px,3vw,40px); letter-spacing: .07em; color: #fff; margin: 0 0 12px; line-height: 1.35; }
.lp-hero h1 span { display: block; font-size: .62em; color: rgba(255,255,255,.76); letter-spacing: .05em; margin-top: 6px; font-weight: 300; }
.lp-hero-desc { font-size: 13.5px; letter-spacing: .04em; color: rgba(255,255,255,.58); line-height: 1.95; max-width: 680px; margin: 0; }

/* SECTIONS */
.lp-sec { width: 100%; padding: 72px 0; background: var(--lt-bg); }
.lp-sec.alt { background: var(--lt-card); }
.lp-sec.mid { background: #f0f5fc; }
.lp-sec.dark { background: var(--dk-bg); color: rgba(255,255,255,.88); }
.lp-sec-label { font-family: var(--mono); font-size: 9.5px; letter-spacing: .42em; color: var(--lt-blue); text-transform: uppercase; display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.lp-sec-label::before { content: ''; width: 18px; height: 1px; background: var(--lt-blue); }
.lp-sec.dark .lp-sec-label { color: #7cb8e8; }
.lp-sec.dark .lp-sec-label::before { background: #7cb8e8; }
.lp-sec-h2 { font-family: var(--serif); font-weight: 400; font-size: clamp(24px,2.4vw,34px); letter-spacing: .07em; color: var(--lt-navy); margin: 0 0 10px; line-height: 1.4; }
.lp-sec.dark .lp-sec-h2 { color: #d8eaf8; }
.lp-sec-desc { font-size: 13.5px; color: var(--lt-text2); letter-spacing: .04em; line-height: 1.95; margin: 0 0 48px; max-width: 580px; }
.lp-sec.dark .lp-sec-desc { color: rgba(255,255,255,.55); }

/* CATEGORY NAV */
.lp-cat-nav { display: grid; grid-template-columns: repeat(6,1fr); gap: 12px; margin-bottom: 0; }
.lp-cat-btn { display: flex; flex-direction: column; align-items: flex-start; padding: 20px 20px 18px; background: var(--lt-card); border: 1px solid var(--lt-bdr); border-radius: 3px; border-top: 3px solid transparent; cursor: pointer; transition: all .2s; text-decoration: none; }
.lp-cat-btn:hover, .lp-cat-btn.active { border-top-color: var(--lt-blue); background: #f6faff; box-shadow: 0 4px 16px rgba(26,46,74,.08); }
.lp-cat-num { font-family: var(--mono); font-size: 10px; letter-spacing: .22em; color: var(--lt-blue); margin-bottom: 10px; }
.lp-cat-icon { width: 32px; height: 32px; border-radius: 2px; background: rgba(42,91,158,.08); border: 1px solid rgba(42,91,158,.16); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
.lp-cat-icon svg { width: 16px; height: 16px; stroke: var(--lt-blue); fill: none; stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
.lp-cat-name { font-family: var(--serif); font-size: 13px; color: var(--lt-navy); font-weight: 400; letter-spacing: .05em; line-height: 1.45; }
.lp-cat-count { font-family: var(--mono); font-size: 9px; color: var(--lt-text3); margin-top: 6px; letter-spacing: .10em; }

/* FEATURED DOCS */
.lp-featured-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 22px; }
.lp-feat-doc { background: var(--lt-card); border: 1px solid var(--lt-bdr); border-radius: 3px; overflow: hidden; transition: box-shadow .22s, transform .22s; display: flex; flex-direction: column; }
.lp-feat-doc:hover { box-shadow: 0 8px 28px rgba(26,46,74,.12); transform: translateY(-4px); }
.lp-feat-doc-header { padding: 26px 26px 22px; background: linear-gradient(135deg,#1a2e4a 0%,#243f6e 100%); position: relative; overflow: hidden; }
.lp-feat-doc-header::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.028) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.028) 1px,transparent 1px); background-size: 30px 30px; }
.lp-feat-badge { display: inline-block; font-family: var(--mono); font-size: 8px; letter-spacing: .18em; padding: 3px 10px; border-radius: 1px; margin-bottom: 14px; position: relative; color: #fff; }
.fb-memo { background: rgba(61,111,168,.8); } .fb-guide { background: rgba(42,122,110,.8); } .fb-check { background: rgba(176,125,43,.8); }
.lp-feat-doc-num { font-family: var(--mono); font-size: 8.5px; letter-spacing: .30em; color: rgba(255,255,255,.38); margin-bottom: 10px; position: relative; }
.lp-feat-doc-ttl { font-family: var(--serif); font-size: 16px; color: #fff; font-weight: 400; letter-spacing: .05em; line-height: 1.5; position: relative; }
.lp-feat-doc-body { padding: 20px 26px 22px; flex: 1; display: flex; flex-direction: column; }
.lp-feat-doc-meta { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; flex: 1; }
.lp-doc-meta-row { display: flex; gap: 10px; font-size: 12px; }
.lp-doc-ml { font-family: var(--mono); font-size: 8.5px; letter-spacing: .14em; color: var(--lt-text3); text-transform: uppercase; min-width: 40px; padding-top: 2px; flex-shrink: 0; }
.lp-doc-mv { color: var(--lt-text2); line-height: 1.6; letter-spacing: .03em; }
.lp-doc-btn { display: inline-flex; align-items: center; gap: 7px; font-family: var(--mono); font-size: 10px; letter-spacing: .16em; color: var(--lt-blue); text-decoration: none; text-transform: uppercase; padding: 8px 0; border-top: 1px solid var(--lt-bdr); transition: gap .18s, color .18s; }
.lp-doc-btn:hover { gap: 12px; color: var(--lt-navy); }
.lp-doc-btn::after { content: '→'; }

/* DOC LIST */
.lp-doc-filter { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 28px; }
.lp-filter-btn { font-family: var(--mono); font-size: 9.5px; letter-spacing: .16em; padding: 6px 14px; border: 1px solid var(--lt-bdr2); border-radius: 2px; color: var(--lt-text3); background: #fff; cursor: pointer; transition: all .15s; text-transform: uppercase; }
.lp-filter-btn:hover { border-color: var(--lt-blue2); color: var(--lt-navy); }
.lp-filter-btn.on { background: var(--lt-blue); border-color: var(--lt-blue); color: #fff; }
.lp-doc-table { width: 100%; border-collapse: collapse; background: var(--lt-card); border: 1px solid var(--lt-bdr); border-radius: 3px; overflow: hidden; }
.lp-doc-table thead tr { background: var(--lt-bg2); }
.lp-doc-table th { font-family: var(--mono); font-size: 8.5px; letter-spacing: .22em; color: var(--lt-text3); text-transform: uppercase; padding: 10px 16px; text-align: left; font-weight: 400; border-bottom: 1px solid var(--lt-bdr); }
.lp-doc-table tbody tr { border-bottom: 1px solid var(--lt-bdr); cursor: pointer; transition: background .13s; }
.lp-doc-table tbody tr:last-child { border-bottom: none; }
.lp-doc-table tbody tr:hover { background: #f2f8ff; }
.lp-doc-table td { padding: 16px 16px; vertical-align: middle; }
.td-num { width: 42px; font-family: var(--mono); font-size: 10px; color: var(--lt-text3); padding-left: 18px !important; position: relative; }
.td-num::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--lt-blue2); transform: scaleY(0); transform-origin: top; transition: transform .18s; }
tr:hover .td-num::before { transform: scaleY(1); }
.td-badge { width: 100px; }
.td-arrow { width: 32px; text-align: right; padding-right: 16px !important; font-family: var(--mono); font-size: 13px; color: var(--lt-bdr2); transition: color .14s, transform .18s; }
tr:hover .td-arrow { color: var(--lt-blue); transform: translateX(3px); }
.lp-badge { display: inline-block; font-family: var(--mono); font-size: 8px; letter-spacing: .12em; padding: 3px 9px; border-radius: 1px; color: #fff; white-space: nowrap; }
.lp-badge.bm { background: var(--lt-blue2); } .lp-badge.bg { background: var(--lt-teal); } .lp-badge.bc { background: var(--lt-gold); } .lp-badge.bs { background: #5a3e8a; }
.lp-doc-ttl { font-size: 13.5px; color: var(--lt-navy); letter-spacing: .04em; font-weight: 400; line-height: 1.5; margin-bottom: 4px; transition: color .14s; }
tr:hover .lp-doc-ttl { color: var(--lt-blue); }
.lp-doc-exc { font-size: 11.5px; color: var(--lt-text3); letter-spacing: .03em; line-height: 1.55; }
.lp-doc-tgt { font-family: var(--mono); font-size: 10px; color: var(--lt-text3); letter-spacing: .06em; line-height: 1.55; }
.lp-doc-table tbody tr.hidden { display: none; }

/* TECH COLUMN CARDS */
.lp-col-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; }
.lp-col-card { background: var(--lt-card); border: 1px solid var(--lt-bdr); border-radius: 3px; overflow: hidden; transition: box-shadow .2s, transform .2s; }
.lp-col-card:hover { box-shadow: 0 6px 20px rgba(26,46,74,.10); transform: translateY(-3px); }
.lp-col-thumb { height: 130px; background: linear-gradient(135deg,#1e3458 0%,#263f68 100%); display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.lp-col-thumb::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px); background-size: 28px 28px; }
.lp-col-cat { position: absolute; top: 10px; left: 10px; z-index: 1; font-family: var(--mono); font-size: 8px; letter-spacing: .14em; padding: 3px 9px; border-radius: 1px; color: #fff; background: var(--lt-teal); }
.lp-col-body { padding: 20px; }
.lp-col-date { font-family: var(--mono); font-size: 10px; color: var(--lt-text3); letter-spacing: .08em; margin-bottom: 8px; }
.lp-col-ttl { font-size: 13.5px; color: var(--lt-navy); letter-spacing: .04em; font-weight: 400; line-height: 1.6; margin-bottom: 10px; transition: color .14s; }
.lp-col-card:hover .lp-col-ttl { color: var(--lt-blue); }
.lp-col-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.lp-col-tag { font-size: 9.5px; letter-spacing: .06em; padding: 3px 8px; border: 1px solid var(--lt-bdr2); color: var(--lt-text3); border-radius: 1px; }
.col-svg { position: relative; z-index: 1; }

/* CTA */
.lp-cta { width: 100%; background: linear-gradient(135deg,#1a2e4a 0%,#1e3557 50%,#243f6e 100%); padding: 72px 0; position: relative; overflow: hidden; }
.lp-cta::before { content: ''; position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px); background-size: 44px 44px; }
.lp-cta-inner { max-width: 760px; margin: 0 auto; padding: 0 48px; text-align: center; position: relative; }
.lp-cta-lbl { font-family: var(--mono); font-size: 9.5px; letter-spacing: .40em; color: #e8b96a; text-transform: uppercase; margin-bottom: 18px; display: flex; align-items: center; justify-content: center; gap: 12px; }
.lp-cta-lbl::before,.lp-cta-lbl::after { content: ''; flex: 1; height: 1px; background: #e8b96a; max-width: 32px; }
.lp-cta h2 { font-family: var(--serif); font-size: 26px; color: #fff; font-weight: 400; letter-spacing: .07em; margin: 0 0 18px; line-height: 1.4; }
.lp-cta p { font-size: 13.5px; color: rgba(255,255,255,.60); letter-spacing: .04em; line-height: 2; margin: 0 0 36px; }
.lp-cta-btns { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
.lp-btn-g { display: inline-flex; align-items: center; gap: 8px; padding: 13px 30px; font-size: 12.5px; letter-spacing: .18em; text-decoration: none; border-radius: 2px; background: var(--dk-gold); color: #fff; border: none; transition: background .2s, transform .2s; }
.lp-btn-g:hover { background: #c48f35; transform: translateY(-2px); }
.lp-btn-w { display: inline-flex; align-items: center; gap: 8px; padding: 13px 30px; font-size: 12.5px; letter-spacing: .18em; text-decoration: none; border-radius: 2px; border: 1px solid rgba(255,255,255,.40); color: rgba(255,255,255,.85); transition: border-color .2s, color .2s; }
.lp-btn-w:hover { border-color: #fff; color: #fff; }

/* FOOTER */
.lp-footer { width: 100%; background: var(--dk-bg2); border-top: 3px solid var(--dk-blue); padding: 36px 48px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.lp-ft-logo { font-family: var(--mono); font-size: 13px; letter-spacing: .20em; color: rgba(255,255,255,.82); font-weight: 600; }
.lp-ft-links { display: flex; gap: 24px; flex-wrap: wrap; }
.lp-ft-links a { font-size: 10px; letter-spacing: .14em; color: rgba(255,255,255,.52); text-decoration: none; transition: color .2s; }
.lp-ft-links a:hover { color: rgba(255,255,255,.85); }
.lp-ft-copy { font-family: var(--mono); font-size: 10px; color: rgba(255,255,255,.35); letter-spacing: .08em; }

/* BACK TO TOP */
.lp-back-top { position: fixed; bottom: 28px; right: 28px; z-index: 9998; width: 42px; height: 42px; background: #fff; border: 1px solid var(--lt-bdr2); border-radius: 2px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all .2s; font-family: var(--mono); font-size: 14px; color: var(--lt-text3); opacity: 0; pointer-events: none; box-shadow: 0 2px 10px rgba(0,0,0,.10); }
.lp-back-top.on { opacity: 1; pointer-events: all; }
.lp-back-top:hover { background: var(--lt-blue); color: #fff; border-color: var(--lt-blue); }

@keyframes lpFU { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }
.lp-hero .lp-inner > * { animation: lpFU .45s ease both; }
.lp-hero .lp-inner > *:nth-child(1) { animation-delay:.05s; }
.lp-hero .lp-inner > *:nth-child(2) { animation-delay:.12s; }
.lp-hero .lp-inner > *:nth-child(3) { animation-delay:.18s; }
.lp-hero .lp-inner > *:nth-child(4) { animation-delay:.24s; }

@media(max-width:1100px) {
  .lp-cat-nav { grid-template-columns: repeat(3,1fr); }
  .lp-featured-grid, .lp-col-grid { grid-template-columns: 1fr 1fr; }
}
@media(max-width:768px) {
  .lp-header { padding: 0 18px; }
  .lp-nav { display: none; }
  .lp-inner, .lp-cta-inner { padding: 0 20px; }
  .lp-hero { padding: 52px 0 44px; }
  .lp-cat-nav { grid-template-columns: 1fr 1fr; }
  .lp-featured-grid, .lp-col-grid { grid-template-columns: 1fr; }
  .lp-doc-table thead { display: none; }
  .lp-sec { padding: 52px 0; }
  .lp-footer { padding: 28px 20px; flex-direction: column; gap: 16px; }
}
</style>
</head>
