<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>お問い合わせ | LANDPLUS.WORK</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;600&family=Noto+Sans+JP:wght@300;400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<style>
html,body{margin:0!important;padding:0!important;}
body{overflow-x:hidden!important;}
.elementor,.elementor-section,.elementor-container,.elementor-column,
.elementor-widget-wrap,.elementor-widget,.elementor-widget-html,
.elementor-widget-container,.e-con,.e-con-inner,.e-con-full,.elementor-element{
  margin:0!important;
  padding:0!important;
  gap:0!important;
  max-width:none!important;
  width:100%!important;
  box-sizing:border-box!important;
}

:root{
  --dk-bg:#1a2e4a;
  --dk-bg2:#152238;
  --dk-blue:#3d6fa8;
  --dk-gold:#b07d2b;
  --dk-grid:rgba(255,255,255,0.033);

  --lt-bg:#f4f7fb;
  --lt-card:#ffffff;
  --lt-navy:#1a2e4a;
  --lt-blue:#2a5b9e;
  --lt-blue2:#3d6fa8;
  --lt-gold:#b07d2b;
  --lt-text:#21364f;
  --lt-text2:#3f566f;
  --lt-text3:#6c8299;
  --lt-bdr:#dce6f0;
  --lt-bdr2:#c4d4e4;
  --lt-bg2:#eaf1f8;

  --mono:'Share Tech Mono',monospace;
  --serif:'Noto Serif JP',serif;
  --sans:'Noto Sans JP',sans-serif;
  --admin-bar:0px;
}

*,*::before,*::after{
  box-sizing:border-box;
}

.lp-contact-page{
  position:relative;
  left:50%;
  transform:translateX(-50%);
  width:100vw;
  background:var(--lt-bg);
  color:var(--lt-text);
  font-family:var(--sans);
  font-weight:400;
  line-height:1.7;
}

.lp-hero{
  width:100%;
  background:linear-gradient(150deg,#152238 0%,#1a3050 40%,#1e3a60 100%);
  padding-top:60px;
  position:relative;
  overflow:hidden;
  min-height:340px;
  display:flex;
  flex-direction:column;
  justify-content:center;
}

.lp-hero::before{
  content:'';
  position:absolute;
  inset:0;
  background-image:
    linear-gradient(var(--dk-grid) 1px,transparent 1px),
    linear-gradient(90deg,var(--dk-grid) 1px,transparent 1px);
  background-size:44px 44px;
}

.lp-hero-deco{
  position:absolute;
  right:0;
  top:0;
  bottom:0;
  width:360px;
  opacity:.055;
  pointer-events:none;
  display:flex;
  align-items:center;
  justify-content:center;
}

.lp-hero-inner{
  max-width:1280px;
  margin:0 auto;
  padding:56px 48px 52px;
  position:relative;
  box-sizing:border-box;
  display:grid;
  grid-template-columns:1fr 420px;
  gap:64px;
  align-items:center;
}

.lp-breadcrumb{
  display:flex;
  align-items:center;
  gap:6px;
  font-family:var(--mono);
  font-size:9.5px;
  letter-spacing:.20em;
  color:rgba(255,255,255,.38);
  margin-bottom:20px;
  text-transform:uppercase;
}

.lp-breadcrumb a{
  color:rgba(255,255,255,.38);
  text-decoration:none;
  transition:color .2s;
}

.lp-breadcrumb a:hover{
  color:rgba(255,255,255,.70);
}

.lp-page-label{
  font-family:var(--mono);
  font-size:10px;
  letter-spacing:.40em;
  color:#e8b96a;
  text-transform:uppercase;
  display:flex;
  align-items:center;
  gap:12px;
  margin-bottom:14px;
}

.lp-page-label::before{
  content:'';
  width:28px;
  height:1px;
  background:#e8b96a;
}

.lp-hero h1{
  font-family:var(--serif);
  font-weight:400;
  font-size:clamp(28px,3vw,42px);
  letter-spacing:.07em;
  color:#fff;
  margin:0 0 16px;
  line-height:1.3;
}

.lp-hero-desc{
  font-size:13.5px;
  letter-spacing:.04em;
  color:rgba(255,255,255,.60);
  line-height:1.95;
  margin:0 0 28px;
}

.lp-hero-contact{
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.10);
  border-radius:4px;
  padding:28px;
}

.lp-hc-head{
  font-family:var(--mono);
  font-size:9px;
  letter-spacing:.30em;
  color:#e8b96a;
  text-transform:uppercase;
  display:flex;
  align-items:center;
  gap:8px;
  margin-bottom:18px;
}

.lp-hc-head::before{
  content:'';
  width:12px;
  height:1px;
  background:#e8b96a;
}

.lp-hc-row{
  display:flex;
  align-items:flex-start;
  gap:14px;
  padding:12px 0;
  border-bottom:1px solid rgba(255,255,255,.07);
}

.lp-hc-row:last-child{
  border-bottom:none;
}

.lp-hc-icon{
  width:32px;
  height:32px;
  border-radius:2px;
  background:rgba(61,111,168,.25);
  border:1px solid rgba(92,141,200,.2);
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
  margin-top:1px;
}

.lp-hc-icon svg{
  width:14px;
  height:14px;
  stroke:#7cb8e8;
  fill:none;
  stroke-width:1.5;
  stroke-linecap:round;
  stroke-linejoin:round;
}

.lp-hc-lbl{
  font-family:var(--mono);
  font-size:8.5px;
  letter-spacing:.18em;
  color:rgba(255,255,255,.38);
  text-transform:uppercase;
  margin-bottom:3px;
}

.lp-hc-val{
  font-size:13.5px;
  color:rgba(255,255,255,.85);
  letter-spacing:.03em;
  line-height:1.6;
}

.lp-hc-val a{
  color:rgba(255,255,255,.85);
  text-decoration:none;
}

.lp-hc-val a:hover{
  color:#fff;
  text-decoration:underline;
}

.lp-hc-sub{
  font-family:var(--mono);
  font-size:9.5px;
  color:rgba(255,255,255,.38);
  letter-spacing:.08em;
  margin-top:2px;
}

.lp-body-wrap{
  width:100%;
  background:var(--lt-bg);
}

.lp-body-inner{
  max-width:1280px;
  margin:0 auto;
  padding:56px 48px 88px;
  display:grid;
  grid-template-columns:320px 1fr;
  gap:48px;
  align-items:start;
  box-sizing:border-box;
}

.lp-left{
  position:sticky;
  top:80px;
}

.lp-flow-block,
.lp-faq-block{
  margin-bottom:32px;
}

.lp-block-head{
  font-family:var(--mono);
  font-size:9px;
  letter-spacing:.36em;
  color:var(--lt-blue);
  text-transform:uppercase;
  display:flex;
  align-items:center;
  gap:8px;
  padding-bottom:10px;
  margin-bottom:16px;
  border-bottom:2px solid var(--lt-bdr);
}

.lp-block-head::before{
  content:'';
  width:12px;
  height:2px;
  background:var(--lt-blue);
}

.lp-step{
  display:flex;
  gap:14px;
  padding:14px 0;
  border-bottom:1px solid var(--lt-bdr);
  position:relative;
}

.lp-step:last-child{
  border-bottom:none;
}

.lp-step-num{
  width:28px;
  height:28px;
  border-radius:50%;
  background:var(--lt-blue);
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:var(--mono);
  font-size:10px;
  color:#fff;
  flex-shrink:0;
  margin-top:2px;
}

.lp-step-ttl{
  font-size:13px;
  color:var(--lt-navy);
  font-weight:500;
  letter-spacing:.04em;
  margin-bottom:3px;
}

.lp-step-txt{
  font-size:11.5px;
  color:var(--lt-text3);
  letter-spacing:.03em;
  line-height:1.7;
}

.lp-faq-list{
  display:flex;
  flex-direction:column;
  gap:8px;
}

.lp-faq-tag{
  display:flex;
  align-items:center;
  gap:8px;
  padding:10px 14px;
  background:var(--lt-card);
  border:1px solid var(--lt-bdr);
  border-radius:2px;
  font-size:12.5px;
  color:var(--lt-text2);
  letter-spacing:.03em;
  line-height:1.5;
}

.lp-faq-dot{
  width:6px;
  height:6px;
  border-radius:50%;
  background:var(--lt-blue);
  flex-shrink:0;
}

.lp-hours-block{
  background:var(--lt-card);
  border:1px solid var(--lt-bdr);
  border-radius:3px;
  overflow:hidden;
}

.lp-hours-head{
  background:var(--lt-navy);
  padding:12px 18px;
  font-family:var(--mono);
  font-size:9px;
  letter-spacing:.28em;
  color:rgba(255,255,255,.65);
  text-transform:uppercase;
}

.lp-hours-body{
  padding:18px;
}

.lp-hours-row{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:8px 0;
  border-bottom:1px solid var(--lt-bdr);
}

.lp-hours-row:last-child{
  border-bottom:none;
}

.lp-hours-day{
  font-family:var(--mono);
  font-size:10px;
  letter-spacing:.10em;
  color:var(--lt-text3);
}

.lp-hours-time{
  font-size:12.5px;
  color:var(--lt-text);
  letter-spacing:.03em;
  font-weight:500;
}

.lp-hours-time.closed{
  color:var(--lt-text3);
  font-weight:400;
}

.lp-form-wrap{
  background:var(--lt-card);
  border:1px solid var(--lt-bdr);
  border-radius:4px;
  overflow:hidden;
}

.lp-form-header{
  background:linear-gradient(135deg,var(--dk-bg) 0%,#1e3a62 100%);
  padding:28px 36px;
  position:relative;
  overflow:hidden;
}

.lp-form-header::before{
  content:'';
  position:absolute;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size:32px 32px;
}

.lp-form-header-label{
  font-family:var(--mono);
  font-size:9px;
  letter-spacing:.36em;
  color:rgba(255,255,255,.40);
  text-transform:uppercase;
  margin-bottom:10px;
  position:relative;
}

.lp-form-header-ttl{
  font-family:var(--serif);
  font-size:20px;
  color:#fff;
  font-weight:400;
  letter-spacing:.06em;
  line-height:1.4;
  position:relative;
  margin-bottom:8px;
}

.lp-form-header-sub{
  font-size:12.5px;
  color:rgba(255,255,255,.50);
  letter-spacing:.03em;
  line-height:1.8;
  position:relative;
}

.lp-form-header-deco{
  position:absolute;
  right:32px;
  top:50%;
  transform:translateY(-50%);
  opacity:.10;
  pointer-events:none;
}

.lp-form-body{
  padding:36px;
}

.lp-form-body .wpcf7,
.lp-form-body .wpcf7-form{
  width:100%!important;
}

.lp-form-body p{
  margin:0 0 22px!important;
}

.lp-form-body label,
.lp-form-body .wpcf7-form label{
  display:block;
  font-family:var(--mono);
  font-size:9.5px;
  letter-spacing:.22em;
  color:var(--lt-text3);
  text-transform:uppercase;
  margin-bottom:7px;
}

.lp-form-body .wpcf7-form-control-wrap{
  display:block!important;
  width:100%!important;
  margin-top:7px;
}

.lp-form-body input[type="text"],
.lp-form-body input[type="email"],
.lp-form-body input[type="tel"],
.lp-form-body input[type="url"],
.lp-form-body select,
.lp-form-body textarea,
.lp-form-body .wpcf7-text,
.lp-form-body .wpcf7-email,
.lp-form-body .wpcf7-tel,
.lp-form-body .wpcf7-textarea,
.lp-form-body .wpcf7-select{
  display:block;
  width:100%;
  background:var(--lt-bg);
  border:1px solid var(--lt-bdr2);
  color:var(--lt-text);
  font-family:var(--sans);
  font-size:13.5px;
  font-weight:300;
  letter-spacing:.03em;
  padding:12px 16px;
  border-radius:2px;
  outline:none;
  transition:border-color .18s,background .18s,box-shadow .18s;
  -webkit-appearance:none;
  appearance:none;
}

.lp-form-body input[type="text"]:focus,
.lp-form-body input[type="email"]:focus,
.lp-form-body input[type="tel"]:focus,
.lp-form-body input[type="url"]:focus,
.lp-form-body select:focus,
.lp-form-body textarea:focus{
  border-color:var(--lt-blue2);
  background:#fff;
  box-shadow:0 0 0 3px rgba(42,91,158,.10);
}

.lp-form-body input::placeholder,
.lp-form-body textarea::placeholder{
  color:var(--lt-text3);
  font-size:12.5px;
}

.lp-form-body textarea,
.lp-form-body .wpcf7-textarea{
  min-height:140px;
  resize:vertical;
  line-height:1.75;
}

.lp-form-body select{
  background-image:
    linear-gradient(45deg,transparent 50%,var(--lt-text3) 50%),
    linear-gradient(135deg,var(--lt-text3) 50%,transparent 50%);
  background-position:
    calc(100% - 20px) 50%,
    calc(100% - 15px) 50%;
  background-size:5px 5px,5px 5px;
  background-repeat:no-repeat;
  padding-right:42px;
}

.lp-form-body .wpcf7-not-valid{
  border-color:#c44a3a!important;
  background:#fff8f8!important;
}

.lp-form-body .wpcf7-not-valid-tip{
  display:block;
  margin-top:5px;
  font-size:11.5px;
  color:#c44a3a;
  letter-spacing:.03em;
}

.lp-form-body .wpcf7-response-output{
  margin:16px 0 0!important;
  padding:12px 16px!important;
  border-radius:2px!important;
  font-size:13px!important;
  line-height:1.8!important;
}

.lp-form-body form.sent .wpcf7-response-output{
  background:#f0faf6!important;
  border:1px solid rgba(42,122,110,.3)!important;
  border-left:3px solid #2a7a6e!important;
  color:#1a5a50!important;
}

.lp-form-body form.invalid .wpcf7-response-output,
.lp-form-body form.failed .wpcf7-response-output,
.lp-form-body form.spam .wpcf7-response-output{
  background:#fff3f3!important;
  border:1px solid rgba(196,74,58,.3)!important;
  border-left:3px solid #c44a3a!important;
  color:#c44a3a!important;
}

.lp-form-body input[type="submit"],
.lp-form-body .wpcf7-submit{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:100%;
  background:var(--lt-blue);
  color:#fff;
  border:none;
  padding:15px 32px;
  font-family:var(--sans);
  font-size:13px;
  letter-spacing:.22em;
  border-radius:2px;
  cursor:pointer;
  transition:background .2s,transform .2s,box-shadow .2s;
  margin-top:6px;
  position:relative;
  overflow:hidden;
}

.lp-form-body input[type="submit"]:hover,
.lp-form-body .wpcf7-submit:hover{
  background:var(--lt-navy);
  transform:translateY(-2px);
  box-shadow:0 6px 20px rgba(26,46,74,.22);
}

.lp-form-body input[type="submit"]:active,
.lp-form-body .wpcf7-submit:active{
  transform:translateY(0);
  box-shadow:none;
}

.lp-form-body .wpcf7-spinner{
  margin-left:10px;
}

.lp-form-body .ajax-loader{
  margin-left:10px;
}

.lp-form-divider{
  height:1px;
  background:var(--lt-bdr);
  margin:28px 0;
}

.lp-privacy-note{
  display:flex;
  gap:10px;
  align-items:flex-start;
  background:var(--lt-bg2);
  border-radius:2px;
  padding:12px 16px;
  margin-top:18px;
}

.lp-privacy-note svg{
  width:14px;
  height:14px;
  stroke:var(--lt-text3);
  fill:none;
  stroke-width:1.5;
  flex-shrink:0;
  margin-top:2px;
}

.lp-privacy-note p{
  font-size:11.5px;
  color:var(--lt-text3);
  letter-spacing:.03em;
  line-height:1.75;
  margin:0!important;
}

.lp-privacy-note a{
  color:var(--lt-blue);
  text-decoration:none;
}

.lp-privacy-note a:hover{
  text-decoration:underline;
}

.lp-faq-acc{
  margin-top:52px;
}

.lp-faq-acc-head{
  font-family:var(--mono);
  font-size:9.5px;
  letter-spacing:.36em;
  color:var(--lt-blue);
  text-transform:uppercase;
  display:flex;
  align-items:center;
  gap:10px;
  padding-bottom:12px;
  margin-bottom:0;
  border-bottom:2px solid var(--lt-bdr);
}

.lp-faq-acc-head::before{
  content:'';
  width:18px;
  height:1px;
  background:var(--lt-blue);
}

.lp-acc-item{
  border-bottom:1px solid var(--lt-bdr);
}

.lp-acc-q{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:16px 4px;
  cursor:pointer;
  font-size:13.5px;
  color:var(--lt-navy);
  letter-spacing:.04em;
  font-weight:400;
  gap:12px;
  user-select:none;
  transition:color .15s;
}

.lp-acc-q:hover{
  color:var(--lt-blue);
}

.lp-acc-icon{
  width:22px;
  height:22px;
  border-radius:50%;
  border:1px solid var(--lt-bdr2);
  flex-shrink:0;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:var(--mono);
  font-size:13px;
  color:var(--lt-blue);
  transition:background .15s,transform .25s;
}

.lp-acc-item.open .lp-acc-icon{
  background:var(--lt-blue);
  color:#fff;
  transform:rotate(45deg);
}

.lp-acc-a{
  font-size:12.5px;
  color:var(--lt-text2);
  letter-spacing:.03em;
  line-height:1.85;
  padding:0 4px 16px;
  display:none;
}

.lp-acc-item.open .lp-acc-a{
  display:block;
}

.lp-cta-banner{
  width:100%;
  background:linear-gradient(135deg,#1a2e4a 0%,#1e3557 50%,#243f6e 100%);
  padding:60px 0;
  position:relative;
  overflow:hidden;
}

.lp-cta-banner::before{
  content:'';
  position:absolute;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(255,255,255,.03) 1px,transparent 1px);
  background-size:44px 44px;
}

.lp-cta-inner{
  max-width:800px;
  margin:0 auto;
  padding:0 48px;
  text-align:center;
  position:relative;
}

.lp-cta-links{
  display:flex;
  gap:20px;
  justify-content:center;
  flex-wrap:wrap;
  margin-top:32px;
}

.lp-cta-link{
  display:inline-flex;
  align-items:center;
  gap:8px;
  font-family:var(--mono);
  font-size:10px;
  letter-spacing:.20em;
  color:rgba(255,255,255,.65);
  text-decoration:none;
  text-transform:uppercase;
  padding:10px 20px;
  border:1px solid rgba(255,255,255,.18);
  border-radius:2px;
  transition:all .18s;
}

.lp-cta-link:hover{
  border-color:rgba(255,255,255,.5);
  color:#fff;
}

.lp-cta-link::after{
  content:'→';
}

.lp-cta-txt{
  font-size:13px;
  color:rgba(255,255,255,.52);
  letter-spacing:.04em;
  line-height:1.9;
  margin-top:14px;
}

.lp-back-top{
  position:fixed;
  bottom:28px;
  right:28px;
  z-index:9998;
  width:42px;
  height:42px;
  background:#fff;
  border:1px solid var(--lt-bdr2);
  border-radius:2px;
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:all .2s;
  font-family:var(--mono);
  font-size:14px;
  color:var(--lt-text3);
  opacity:0;
  pointer-events:none;
  box-shadow:0 2px 10px rgba(0,0,0,.10);
}

.lp-back-top.on{
  opacity:1;
  pointer-events:all;
}

.lp-back-top:hover{
  background:var(--lt-blue);
  color:#fff;
  border-color:var(--lt-blue);
}

@keyframes lpFU{
  from{opacity:0;transform:translateY(14px)}
  to{opacity:1;transform:translateY(0)}
}

.lp-hero-inner>*{
  animation:lpFU .45s ease both;
}

.lp-hero-inner>*:nth-child(1){
  animation-delay:.05s;
}

.lp-hero-inner>*:nth-child(2){
  animation-delay:.15s;
}

@media(max-width:1024px){
  .lp-hero-inner{
    grid-template-columns:1fr;
    gap:36px;
