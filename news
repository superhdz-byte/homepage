const LP_PER = 10;
let LP_NEWS = [];
const LP_STATE = { cat: 'all', year: 'all', tags: [], sort: 'desc', page: 1 };

function lpTextOnly(html) {
  const div = document.createElement("div");
  div.innerHTML = html || "";
  return div.textContent || div.innerText || "";
}

function lpEscapeHtml(str) {
  return String(str || "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");
}

function lpGetPostTerms(post) {
  const result = { categories: [], tags: [] };

  if (!post._embedded || !post._embedded["wp:term"]) {
    return result;
  }

  post._embedded["wp:term"].forEach(group => {
    group.forEach(term => {
      if (term.taxonomy === "category") result.categories.push(term);
      if (term.taxonomy === "post_tag") result.tags.push(term);
    });
  });

  return result;
}

function lpBadgeClassByName(name) {
  if (name === "更新情報") return "lp-badge-update";
  if (name === "技術コラム") return "lp-badge-tech";
  if (name === "メディア掲載") return "lp-badge-media";
  if (name === "モデル作成") return "lp-badge-tech";
  if (name === "土木設計") return "lp-badge-update";
  if (name === "耐震解析") return "lp-badge-info";
  return "lp-badge-info";
}

function lpFormatDate(dateText) {
  const d = new Date(dateText);
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  return y + "." + m + "." + day;
}

function lpIsNewPost(dateText) {
  const postDate = new Date(dateText);
  const now = new Date();
  const days = (now - postDate) / (1000 * 60 * 60 * 24);
  return days <= 30;
}

function lpConvertPost(post) {
  const terms = lpGetPostTerms(post);
  const mainCat = terms.categories[0] || { name: "お知らせ", slug: "news" };

  const excerptText = lpTextOnly(post.excerpt && post.excerpt.rendered ? post.excerpt.rendered : "");
  const titleText = lpTextOnly(post.title && post.title.rendered ? post.title.rendered : "無題");

  return {
    id: post.id,
    date: post.date.substring(0, 10),
    link: post.link,
    cat: mainCat.slug || "news",
    catName: mainCat.name || "お知らせ",
    badge: mainCat.name || "お知らせ",
    cls: lpBadgeClassByName(mainCat.name || "お知らせ"),
    title: titleText,
    excerpt: excerptText || "詳細は記事ページをご確認ください。",
    tags: terms.tags.map(t => t.name),
    year: post.date.substring(0, 4),
    isNew: lpIsNewPost(post.date)
  };
}

function lpLoadPosts() {
  const tb = document.getElementById("lpNewsBody");

  if (tb) {
    tb.innerHTML = '<tr class="lp-empty-row"><td colspan="4">投稿を読み込み中です。</td></tr>';
  }

  fetch(window.location.origin + "/wp-json/wp/v2/posts?per_page=100&_embed=1")
    .then(response => {
      if (!response.ok) {
        throw new Error("REST API error");
      }
      return response.json();
    })
    .then(posts => {
      LP_NEWS = posts.map(lpConvertPost);
      lpBuildSidebar();
      lpRender();
    })
    .catch(error => {
      console.error(error);

      if (tb) {
        tb.innerHTML = '<tr class="lp-empty-row"><td colspan="4">投稿を取得できませんでした。WordPress REST API または投稿の公開状態を確認してください。</td></tr>';
      }

      const rc = document.getElementById("lpResultCount");
      if (rc) rc.innerHTML = '<em>0</em> 件のお知らせ';

      const cat = document.getElementById("lpCatList");
      const year = document.getElementById("lpYearList");
      const tag = document.getElementById("lpTagCloud");

      if (cat) {
        cat.innerHTML = '<li><button class="lp-cat-btn active" type="button"><span class="lp-cat-name">取得失敗</span><span class="lp-cat-count">0</span></button></li>';
      }

      if (year) {
        year.innerHTML = '<li><button class="lp-year-btn active" type="button">取得失敗</button></li>';
      }

      if (tag) {
        tag.innerHTML = '<span class="lp-tag-empty">タグを取得できませんでした</span>';
      }
    });
}

function lpBuildSidebar() {
  lpBuildCategoryList();
  lpBuildYearList();
  lpBuildTagList();
}

function lpBuildCategoryList() {
  const catList = document.getElementById("lpCatList");
  if (!catList) return;

  const counts = {};

  LP_NEWS.forEach(n => {
    if (!counts[n.cat]) {
      counts[n.cat] = { slug: n.cat, name: n.catName, count: 0 };
    }
    counts[n.cat].count++;
  });

  let html = `
    <li>
      <button class="lp-cat-btn active" type="button" data-cat="all">
        <span class="lp-cat-name">すべて</span>
        <span class="lp-cat-count">${LP_NEWS.length}</span>
      </button>
    </li>
  `;

  Object.values(counts).forEach(c => {
    html += `
      <li>
        <button class="lp-cat-btn" type="button" data-cat="${lpEscapeHtml(c.slug)}">
          <span class="lp-cat-name">${lpEscapeHtml(c.name)}</span>
          <span class="lp-cat-count">${c.count}</span>
        </button>
      </li>
    `;
  });

  catList.innerHTML = html;

  catList.querySelectorAll(".lp-cat-btn").forEach(btn => {
    btn.addEventListener("click", function () {
      LP_STATE.cat = this.dataset.cat || "all";
      LP_STATE.page = 1;

      document.querySelectorAll(".lp-cat-btn").forEach(b => b.classList.remove("active"));
      this.classList.add("active");

      lpRender();
    });
  });
}

function lpBuildYearList() {
  const yearList = document.getElementById("lpYearList");
  if (!yearList) return;

  const years = [...new Set(LP_NEWS.map(n => n.year))].sort((a, b) => b.localeCompare(a));

  let html = `
    <li>
      <button class="lp-year-btn active" type="button" data-year="all">すべての年</button>
    </li>
  `;

  years.forEach(y => {
    html += `
      <li>
        <button class="lp-year-btn" type="button" data-year="${lpEscapeHtml(y)}">${lpEscapeHtml(y)}年</button>
      </li>
    `;
  });

  yearList.innerHTML = html;

  yearList.querySelectorAll(".lp-year-btn").forEach(btn => {
    btn.addEventListener("click", function () {
      LP_STATE.year = this.dataset.year || "all";
      LP_STATE.page = 1;

      document.querySelectorAll(".lp-year-btn").forEach(b => b.classList.remove("active"));
      this.classList.add("active");

      lpRender();
    });
  });
}

function lpBuildTagList() {
  const tagCloud = document.getElementById("lpTagCloud");
  if (!tagCloud) return;

  const tagSet = new Set();

  LP_NEWS.forEach(n => {
    n.tags.forEach(t => tagSet.add(t));
  });

  const tags = [...tagSet];

  if (!tags.length) {
    tagCloud.innerHTML = '<span class="lp-tag-empty">タグはありません</span>';
    return;
  }

  tagCloud.innerHTML = tags.map(t => `
    <button class="lp-tag-pill" type="button" data-tag="${lpEscapeHtml(t)}">${lpEscapeHtml(t)}</button>
  `).join("");

  tagCloud.querySelectorAll(".lp-tag-pill").forEach(btn => {
    btn.addEventListener("click", function () {
      const tag = this.dataset.tag;
      this.classList.toggle("active");

      LP_STATE.tags = LP_STATE.tags.includes(tag)
        ? LP_STATE.tags.filter(t => t !== tag)
        : [...LP_STATE.tags, tag];

      LP_STATE.page = 1;
      lpRender();
    });
  });
}

function lpFiltered() {
  let d = [...LP_NEWS];

  if (LP_STATE.cat !== "all") {
    d = d.filter(n => n.cat === LP_STATE.cat);
  }

  if (LP_STATE.year !== "all") {
    d = d.filter(n => n.year === LP_STATE.year);
  }

  if (LP_STATE.tags.length) {
    d = d.filter(n => LP_STATE.tags.every(t => n.tags.includes(t)));
  }

  d.sort((a, b) => {
    return LP_STATE.sort === "asc"
      ? a.date.localeCompare(b.date)
      : b.date.localeCompare(a.date);
  });

  return d;
}

function lpRender() {
  const data = lpFiltered();
  const total = data.length;
  const pages = Math.max(1, Math.ceil(total / LP_PER));

  if (LP_STATE.page > pages) LP_STATE.page = pages;

  const slice = data.slice((LP_STATE.page - 1) * LP_PER, LP_STATE.page * LP_PER);

  const resultCount = document.getElementById("lpResultCount");
  if (resultCount) {
    resultCount.innerHTML = `<em>${total}</em> 件のお知らせ`;
  }

  const tb = document.getElementById("lpNewsBody");
  if (!tb) return;

  tb.innerHTML = !slice.length
    ? '<tr class="lp-empty-row"><td colspan="4">該当するお知らせはありません。</td></tr>'
    : slice.map((n, i) => `
        <tr style="animation-delay:${i * 0.03}s" data-link="${lpEscapeHtml(n.link)}">
          <td class="lp-td-date">${lpFormatDate(n.date)}</td>
          <td class="lp-td-badge"><span class="lp-badge ${lpEscapeHtml(n.cls)}">${lpEscapeHtml(n.badge)}</span></td>
          <td class="lp-td-title">
            <div class="lp-news-ttl">
              ${lpEscapeHtml(n.title)}
              ${n.isNew ? '<span class="lp-new-mark">NEW</span>' : ''}
            </div>
            <div class="lp-news-exc">${lpEscapeHtml(n.excerpt)}</div>
          </td>
          <td class="lp-td-arrow">→</td>
        </tr>
      `).join("");

  tb.querySelectorAll("tr[data-link]").forEach(row => {
    row.addEventListener("click", function () {
      const link = this.dataset.link;
      if (link) window.location.href = link;
    });
  });

  lpRenderPagination(pages);
}

function lpRenderPagination(pages) {
  const pg = document.getElementById("lpPagination");
  if (!pg) return;

  if (pages <= 1) {
    pg.innerHTML = "";
    return;
  }

  const p = LP_STATE.page;
  let html = `<button class="lp-pg-btn" type="button" data-page="${p - 1}" ${p === 1 ? "disabled" : ""}>←</button>`;

  for (let i = 1; i <= pages; i++) {
    if (pages > 7 && i !== 1 && i !== pages && Math.abs(i - p) > 1) {
      if (i === p - 2 || i === p + 2) html += '<span class="lp-pg-dot">…</span>';
      continue;
    }

    html += `<button class="lp-pg-btn${i === p ? " active" : ""}" type="button" data-page="${i}">${i}</button>`;
  }

  html += `<button class="lp-pg-btn" type="button" data-page="${p + 1}" ${p === pages ? "disabled" : ""}>→</button>`;

  pg.innerHTML = html;

  pg.querySelectorAll(".lp-pg-btn").forEach(btn => {
    btn.addEventListener("click", function () {
      const page = Number(this.dataset.page);
      if (!page || this.disabled) return;

      LP_STATE.page = page;
      lpRender();

      const bodyWrap = document.querySelector(".lp-body-wrap");
      if (bodyWrap) {
        window.scrollTo({
          top: bodyWrap.offsetTop - 70,
          behavior: "smooth"
        });
      }
    });
  });
}

const lpSortSel = document.getElementById("lpSortSel");
if (lpSortSel) {
  lpSortSel.addEventListener("change", function () {
    LP_STATE.sort = this.value;
    LP_STATE.page = 1;
    lpRender();
  });
}

const lpBackTop = document.getElementById("lpBackTop");
if (lpBackTop) {
  lpBackTop.addEventListener("click", function () {
    window.scrollTo({ top: 0, behavior: "smooth" });
  });

  window.addEventListener("scroll", function () {
    lpBackTop.classList.toggle("on", window.scrollY > 300);
  });
}

lpLoadPosts();
</script>

</body>
</html>
