<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LANDPLUS.WORK | 上下水道施設の耐震解析・補強設計</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;600&family=Noto+Sans+JP:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#1a2e4a;--navy-2:#243f6a;--blue:#2f60a0;--blue-lt:#4e7fc0;
  --blue-pale:#e8f0fb;--gold:#b47a21;--gold-lt:#d4973a;--teal:#1e6a5e;
  --bg:#f4f7fb;--bg-white:#ffffff;--bg-pale:#eef3fa;
  --text:#162033;--text-2:#3f5070;--text-3:#7a96b4;
  --border:#d6e0ee;--border-lt:#eaf0f8;
  --shadow-sm:0 2px 8px rgba(26,46,74,.07);
  --shadow-md:0 6px 24px rgba(26,46,74,.11);
  --shadow-lg:0 12px 40px rgba(26,46,74,.15);
  --mono:"Share Tech Mono",monospace;
  --serif:"Noto Serif JP",serif;
  --sans:"Noto Sans JP",sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--sans);font-weight:400;overflow-x:hidden;line-height:1.75;-webkit-font-smoothing:antialiased}

/* HEADER */
header{position:fixed;top:0;left:0;right:0;z-index:200;background:var(--navy);display:flex;align-items:center;justify-content:space-between;padding:0 52px;height:66px;box-shadow:0 2px 16px rgba(26,46,74,.35);transition:height .25s,box-shadow .25s}
header.scrolled{height:58px}
.logo{text-decoration:none;display:flex;flex-direction:column;gap:2px}
.logo-main{font-family:var(--mono);font-size:15px;letter-spacing:.20em;color:#fff;font-weight:600}
.logo-sub{font-size:9px;letter-spacing:.24em;color:rgba(255,255,255,.45);text-transform:uppercase}


/* HERO */
.hero{background:linear-gradient(140deg,#1a2e4a 0%,#1e3a62 48%,#2a5285 100%);min-height:75vh;display:flex;flex-direction:column;justify-content:center;padding:130px calc(72px + 16.6667%) 128px calc(72px + 16.6667%);position:relative;overflow:hidden}
.hero::before{content:"";position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.032) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.032) 1px,transparent 1px);background-size:52px 52px;pointer-events:none}
.hero::after{content:"";position:absolute;right:-80px;top:-100px;width:700px;height:700px;background:radial-gradient(circle,rgba(92,140,200,.12) 0%,transparent 60%);pointer-events:none}
.hero-diagram{position:absolute;right:60px;top:50%;transform:translateY(-50%);opacity:.11;pointer-events:none;width:520px}
.hero-eyebrow{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.50em;color:#d4a040;text-transform:uppercase;margin-bottom:28px;display:flex;align-items:center;gap:16px;animation:fadeUp .5s ease both}
.hero-eyebrow::before{content:"";width:40px;height:1px;background:#d4a040}
h1{font-family:var(--serif);font-weight:400;font-size:clamp(32px,3.6vw,54px);line-height:1.50;letter-spacing:.04em;color:#fff;margin-bottom:30px;max-width:700px;text-shadow:0 2px 14px rgba(0,0,0,.22);animation:fadeUp .55s .08s ease both}
h1 em{font-style:normal;color:#9dcef8;font-weight:500}
.hero-lead{font-size:15.5px;line-height:2.05;letter-spacing:.04em;font-weight:500;color:rgba(255,255,255,.86);max-width:540px;margin-bottom:46px;animation:fadeUp .55s .16s ease both}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;animation:fadeUp .55s .24s ease both}
.btn-g{display:inline-flex;align-items:center;gap:10px;background:var(--gold);color:#fff;padding:15px 38px;font-size:12px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background .2s,transform .2s}
.btn-g:hover{background:var(--gold-lt);transform:translateX(3px)}
.btn-o{display:inline-flex;align-items:center;gap:10px;border:1.5px solid rgba(255,255,255,.42);color:rgba(255,255,255,.88);padding:15px 38px;font-size:12px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:border-color .2s,color .2s,background .2s}
.btn-o:hover{border-color:#fff;color:#fff;background:rgba(255,255,255,.07)}
.hero-metrics{position:absolute;bottom:60px;right:72px;display:flex;gap:56px;animation:fadeUp .55s .32s ease both}
.metric{text-align:right}
.metric-num{font-family:var(--mono);font-size:30px;font-weight:600;color:#fff;display:block;line-height:1}
.metric-label{font-size:9.5px;letter-spacing:.24em;color:rgba(255,255,255,.45);margin-top:6px;text-transform:uppercase}

/* SECTION BASE */
.sec-inner{max-width:1200px;margin:0 auto;padding:96px 52px}
.sec-label{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.48em;color:var(--blue);text-transform:uppercase;margin-bottom:12px;display:flex;align-items:center;gap:12px}
.sec-label::before{content:"";width:24px;height:2px;background:var(--blue)}
h2{font-family:var(--serif);font-weight:500;font-size:clamp(24px,2.8vw,38px);letter-spacing:.05em;color:var(--navy);margin-bottom:16px;line-height:1.4}
.sec-desc{font-size:15px;color:var(--text-2);letter-spacing:.03em;line-height:1.95;margin-bottom:60px;max-width:540px;font-weight:400}

/* PAIN — LIGHT */
.pain-sec{background:var(--bg-pale)}
.pain-sec .sec-label{color:#5a7898}.pain-sec .sec-label::before{background:#5a7898}
.pain-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.pain-card{background:var(--bg-white);border-radius:4px;padding:40px 34px;border-top:3px solid var(--gold);box-shadow:var(--shadow-sm);transition:box-shadow .25s,transform .25s}
.pain-card:hover{box-shadow:var(--shadow-md);transform:translateY(-3px)}
.pain-icon{width:52px;height:52px;border-radius:10px;background:var(--blue-pale);display:flex;align-items:center;justify-content:center;margin-bottom:20px}
.pain-icon svg{width:24px;height:24px;stroke:var(--blue);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.pain-title{font-size:17px;font-weight:700;color:var(--navy);margin-bottom:14px;line-height:1.5;letter-spacing:.03em}
.pain-body{font-size:14px;color:var(--text-2);line-height:1.95}

/* VALUE */
.value-sec{background:var(--bg-white)}
.value-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:1px solid var(--border)}
.value-card{padding:44px 38px;border-right:1px solid var(--border);position:relative;transition:background .2s}
.value-card:last-child{border-right:none}
.value-card::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--blue);transform:scaleX(0);transform-origin:left;transition:transform .3s}
.value-card:hover::before{transform:scaleX(1)}
.value-card:hover{background:var(--bg-pale)}
.value-num{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--blue);letter-spacing:.25em;margin-bottom:20px;display:flex;align-items:center;gap:10px}
.value-num::after{content:"";flex:1;height:1px;background:var(--border)}
.value-title{font-family:var(--serif);font-size:20px;font-weight:500;color:var(--navy);margin-bottom:14px;line-height:1.5;letter-spacing:.04em}
.value-body{font-size:14px;color:var(--text-2);line-height:1.95}

/* SERVICES - boxed layout */
.srv-sec{
  background:var(--bg-pale);
  border-top:1px solid var(--border-lt);
}

.srv-inner{
  max-width:1200px;
  padding:96px 52px;
}

.srv-sec .sec-desc{
  margin-bottom:58px;
}

.srv-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
  border:1px solid var(--border);
  background:#ffffff;
}

.srv-card{
  background:#ffffff;
  min-height:332px;
  padding:48px 38px 42px;
  border-right:1px solid var(--border);
  border-bottom:1px solid var(--border);
  position:relative;
  transition:background .22s ease, box-shadow .22s ease, transform .22s ease;
}

.srv-card:nth-child(3n){
  border-right:none;
}

.srv-card:nth-child(n+4){
  border-bottom:none;
}

.srv-card:hover{
  background:#f7faff;
  box-shadow:0 10px 28px rgba(26,46,74,.08);
  transform:translateY(-2px);
  z-index:2;
}

.srv-num{
  font-family:var(--mono);
  font-size:13px;
  font-weight:700;
  color:var(--blue);
  letter-spacing:.24em;
  margin-bottom:28px;
  display:flex;
  align-items:center;
  gap:16px;
}

.srv-num::after{
  content:"";
  flex:1;
  height:1px;
  background:var(--border);
}

.srv-title{
  font-family:var(--serif);
  font-size:24px;
  font-weight:500;
  color:var(--navy);
  line-height:1.55;
  letter-spacing:.04em;
  margin-bottom:20px;
}

.srv-body{
  font-size:14px;
  color:var(--text-2);
  line-height:2.05;
  letter-spacing:.03em;
}

/* tablet */
@media(max-width:1024px){
  .srv-grid{
    grid-template-columns:repeat(2,1fr);
  }

  .srv-card{
    border-right:1px solid var(--border);
    border-bottom:1px solid var(--border);
  }

  .srv-card:nth-child(3n){
    border-right:1px solid var(--border);
  }

  .srv-card:nth-child(2n){
    border-right:none;
  }

  .srv-card:nth-child(n+5){
    border-bottom:none;
  }
}

/* mobile */
@media(max-width:767px){
  .srv-inner{
    padding:72px 22px;
  }

  .srv-grid{
    grid-template-columns:1fr;
  }

  .srv-card{
    min-height:auto;
    padding:36px 28px;
    border-right:none !important;
    border-bottom:1px solid var(--border) !important;
  }

  .srv-card:last-child{
    border-bottom:none !important;
  }

  .srv-title{
    font-size:21px;
  }
}

/* DIFF */
.diff-sec{background:var(--bg-white)}
.diff-grid{display:grid;grid-template-columns:1fr 1fr;gap:28px}
.diff-card{border:1px solid var(--border);border-radius:4px;padding:44px 40px;display:grid;grid-template-columns:80px 1fr;gap:32px;align-items:start;transition:box-shadow .25s,border-color .25s}
.diff-card:hover{box-shadow:var(--shadow-md);border-color:var(--blue)}
.diff-badge{width:80px;height:80px;background:var(--navy);border-radius:4px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;flex-shrink:0}
.diff-badge-top{font-family:var(--mono);font-size:16px;font-weight:700;color:#9dcef8;line-height:1}
.diff-badge-sub{font-size:8px;letter-spacing:.14em;color:rgba(255,255,255,.48);text-transform:uppercase;line-height:1}
.diff-content h3{font-family:var(--serif);font-size:21px;font-weight:500;color:var(--navy);margin-bottom:12px;line-height:1.45;letter-spacing:.04em}
.diff-content p{font-size:14px;color:var(--text-2);line-height:1.95}
.diff-chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:18px}
.chip{font-size:10.5px;font-weight:600;padding:4px 12px;background:var(--blue-pale);color:var(--blue);border-radius:2px;letter-spacing:.08em}

/* COLLAB */
.collab-sec{background:var(--bg-pale)}
.collab-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.collab-card{background:var(--bg-white);border:1px solid var(--border);border-radius:4px;padding:40px 34px;transition:box-shadow .25s,transform .25s}
.collab-card:hover{box-shadow:var(--shadow-lg);transform:translateY(-4px)}
.collab-letter{font-family:var(--mono);font-size:56px;font-weight:700;color:var(--border);line-height:1;margin-bottom:6px}
.collab-type{font-size:10.5px;font-weight:700;letter-spacing:.28em;color:var(--blue);text-transform:uppercase;margin-bottom:18px}
.collab-title{font-family:var(--serif);font-size:19px;font-weight:500;color:var(--navy);margin-bottom:14px;line-height:1.5}
.collab-body{font-size:14px;color:var(--text-2);line-height:1.95}
.collab-cta{margin-top:40px;background:var(--navy);padding:30px 40px;border-radius:4px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:24px}
.collab-cta p{font-size:15px;font-weight:500;color:rgba(255,255,255,.90);letter-spacing:.04em}

/* WORKS — LIGHT */
.works-sec{background:var(--bg-white)}
.works-sec .sec-inner{padding-bottom:64px}
.works-sec .sec-label{color:#5a7898}.works-sec .sec-label::before{background:#5a7898}
.works-sec h2{color:var(--navy)}
.works-sec .sec-desc{color:var(--text-2);margin-bottom:48px}
.works-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;padding-bottom:20px}
.wk-card{background:var(--bg-white);border:1px solid var(--border);border-radius:3px;overflow:hidden;display:flex;flex-direction:column;transition:box-shadow .22s,transform .22s,border-color .22s;cursor:pointer}
.wk-card:hover{box-shadow:var(--shadow-md);transform:translateY(-5px);border-color:var(--blue)}
.wk-img{height:168px;background:var(--bg-pale);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;flex-shrink:0}
.wk-img::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,transparent 55%,rgba(238,243,250,.9) 100%);pointer-events:none}
.wk-cat{position:absolute;top:12px;left:12px;z-index:1;font-family:var(--mono);font-size:8.5px;font-weight:700;letter-spacing:.16em;color:#fff;background:var(--blue);padding:4px 10px;border-radius:1px;text-transform:uppercase}
.wk-cat.gold{background:var(--gold)}.wk-cat.teal{background:var(--teal)}
.wk-body{padding:22px;flex:1;display:flex;flex-direction:column}
.wk-meta{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.wk-date{font-family:var(--mono);font-size:10.5px;font-weight:700;color:var(--text-3);letter-spacing:.08em}
.wk-fac{font-family:var(--mono);font-size:9px;font-weight:700;letter-spacing:.14em;color:var(--blue);text-transform:uppercase}
.wk-title{font-size:14px;font-weight:500;line-height:1.70;letter-spacing:.04em;color:var(--navy);margin-bottom:14px;flex:1}
.wk-tags{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:16px}
.wk-tag{font-size:9px;letter-spacing:.09em;padding:3px 9px;border:1px solid var(--border);color:var(--text-3);border-radius:1px}
.wk-detail{border-top:1px solid var(--border-lt);padding-top:14px;display:grid;grid-template-columns:1fr 1fr;gap:10px}
.wk-dl{font-family:var(--mono);font-size:8.5px;letter-spacing:.12em;color:var(--text-3);text-transform:uppercase;margin-bottom:3px}
.wk-dv{font-size:12px;color:var(--text-2);letter-spacing:.03em;line-height:1.5}
.dl{stroke:rgba(100,136,168,.52);stroke-width:1;fill:none}
.dl2{stroke:rgba(100,136,168,.30);stroke-width:.8;fill:none}
.da{stroke:#b47a21;stroke-width:1.5;fill:none}
.dg{stroke:rgba(74,111,140,.62);stroke-width:1.8;fill:none}
.df{fill:rgba(92,133,173,.15);stroke:rgba(120,170,220,.5);stroke-width:.8}
.dfg{fill:rgba(176,125,43,.12);stroke:rgba(220,170,80,.6);stroke-width:.8}
.dt{fill:rgba(75,101,128,.72);font-family:monospace;font-size:8px}
.works-footer{border-top:1px solid var(--border-lt);display:flex;align-items:center;justify-content:space-between;padding:28px 0}
.works-summary{display:flex;gap:40px}
.ws-item{display:flex;flex-direction:column;gap:3px}
.ws-num{font-family:var(--mono);font-size:20px;font-weight:600;color:var(--navy);line-height:1}
.ws-num span{font-size:12px;color:var(--text-3);margin-left:2px}
.ws-label{font-size:11px;color:var(--text-3);letter-spacing:.08em}
.view-all{font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--blue);text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:gap .2s,color .2s;margin-top:26px}
.view-all::after{content:"->"}
.view-all:hover{gap:16px;color:#4e7fc0}

.lp-news-section {
  background: #eef4fb;
  padding: 90px 0 120px;
  overflow: visible;
}

.lp-news-inner {
  width: min(986px, calc(100% - 48px));
  margin: 0 auto;
}

.lp-sec-label {
  font-size: 10px;
  letter-spacing: 0.45em;
  font-weight: 700;
  color: #315a9a;
  margin-bottom: 20px;
}

.lp-sec-title {
  margin: 0 0 22px;
  font-size: 32px;
  line-height: 1.4;
  font-weight: 500;
  color: #071735;
  letter-spacing: 0.08em;
}

.lp-sec-desc {
  margin: 0 0 54px;
  font-size: 14px;
  line-height: 1.9;
  color: #1e3558;
}

.lp-news-card {
  background: #ffffff;
  border: 1px solid #cbd8ea;
  border-radius: 3px;
  overflow: hidden;
}

#lp-auto-news {
  margin: 0 !important;
}

#lp-auto-news .lp-news-item {
  display: grid;
  grid-template-columns: 110px 92px 1fr;
  align-items: center;
  gap: 20px;
  min-height: 56px;
  padding: 14px 24px;
  border-bottom: 1px solid #e2e8f0;
  text-decoration: none;
  color: #071735;
}

#lp-auto-news .lp-news-item:last-child {
  border-bottom: none;
}

#lp-auto-news .lp-news-date {
  font-size: 12px;
  letter-spacing: 0.16em;
  color: #315a9a;
  font-weight: 700;
}

#lp-auto-news .lp-news-cat {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 74px;
  padding: 5px 10px;
  font-size: 11px;
  line-height: 1;
  color: #ffffff;
  font-weight: 700;
  border-radius: 1px;
}

#lp-auto-news .lp-news-cat-default {
  background: #3f5f98;
}

#lp-auto-news .lp-news-cat-blue {
  background: #3f5f98;
}

#lp-auto-news .lp-news-cat-green {
  background: #28705d;
}

#lp-auto-news .lp-news-cat-brown {
  background: #a87b25;
}

#lp-auto-news .lp-news-title {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.7;
  color: #071735;
  white-space: normal;
}

.lp-news-more {
  display: inline-block;
  margin-top: 38px;
  font-size: 13px;
  letter-spacing: 0.12em;
  font-weight: 700;
  color: #315a9a;
  text-decoration: none;
}

@media (max-width: 767px) {
  .lp-news-section {
    padding: 64px 0 86px;
  }

  .lp-news-inner {
    width: min(100% - 32px, 986px);
  }

  .lp-sec-title {
    font-size: 28px;
  }

  #lp-auto-news .lp-news-item {
    grid-template-columns: 1fr;
    gap: 8px;
    padding: 18px;
  }

  #lp-auto-news .lp-news-cat {
    width: fit-content;
  }
}

/* CTA */
.cta-sec{background:linear-gradient(135deg,#1a2e4a 0%,#1e3a62 55%,#2a5285 100%);position:relative;overflow:hidden}
.cta-sec::before{content:"";position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.028) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.028) 1px,transparent 1px);background-size:52px 52px}
.cta-inner{max-width:1200px;margin:0 auto;padding:100px 52px;display:grid;grid-template-columns:1fr auto;gap:72px;align-items:center;position:relative}
.cta-label{font-family:var(--mono);font-size:10px;font-weight:700;letter-spacing:.48em;color:#d4a040;text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:12px}
.cta-label::before{content:"";width:24px;height:2px;background:#d4a040}
.cta-inner h2{font-family:var(--serif);font-size:clamp(22px,2.4vw,34px);font-weight:400;color:#fff;letter-spacing:.05em;line-height:1.55;margin-bottom:20px}
.cta-inner p{font-size:15px;color:rgba(255,255,255,.72);line-height:1.95;max-width:500px;margin-bottom:36px}
.cta-contact{display:flex;flex-direction:column;gap:20px;min-width:300px}
.cta-ci{display:flex;flex-direction:column;gap:4px}
.cta-cl{font-family:var(--mono);font-size:9px;letter-spacing:.32em;color:rgba(255,255,255,.40);text-transform:uppercase}
.cta-cv{font-size:14px;font-weight:500;color:rgba(255,255,255,.88)}

/* FOOTER */
footer{background:#0f1d2e;border-top:3px solid var(--blue);padding:44px 52px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px}
.ft-left{display:flex;flex-direction:column;gap:6px}
